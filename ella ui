local DEFAULT_THEME = {
    Background = Color3.fromRGB(16, 17, 22),
    TopBar = Color3.fromRGB(20, 21, 28),
    Surface = Color3.fromRGB(24, 26, 34),
    SurfaceSoft = Color3.fromRGB(21, 22, 29),
    Input = Color3.fromRGB(31, 33, 43),
    Text = Color3.fromRGB(242, 245, 255),
    SubText = Color3.fromRGB(168, 174, 200),
    Accent = Color3.fromRGB(0, 170, 255)
}

local function resolveGuiParent()
    if typeof(gethui) == "function" then
        local ok, gui = pcall(gethui)
        if ok and typeof(gui) == "Instance" then
            return gui
        end
    end

    if typeof(cloneref) == "function" then
        local ok, gui = pcall(function()
            return cloneref(CoreGui)
        end)
        if ok and typeof(gui) == "Instance" then
            return gui
        end
    end

    return CoreGui
end

local function safeProtectGui(gui)
    if syn and syn.protect_gui then
        pcall(function()
            syn.protect_gui(gui)
        end)
    end
end

local function applyCorner(instance, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 8)
    corner.Parent = instance
    return corner
end

local function makeStroke(instance, color, transparency)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1
    stroke.Color = color or Color3.fromRGB(50, 54, 70)
    stroke.Transparency = transparency or 0.2
    stroke.Parent = instance
    return stroke
end

local function shallowCopy(tbl)
    local out = {}
    for k, v in pairs(tbl) do
        out[k] = v
    end
    return out
end

local function loadFloatingBar()
    local ok1, bar1 = pcall(function()
        if type(loadfile) == "function" then
            local chunk = loadfile("UI Library/src.lua")
            if type(chunk) == "function" then
                return chunk()
            end
        end
        return nil
    end)
    if ok1 and type(bar1) == "table" and type(bar1.Notify) == "function" then
        return bar1
    end

    local ok2, bar2 = pcall(function()
        if type(readfile) == "function" and type(loadstring) == "function" then
            local source = readfile("UI Library/src.lua")
            local chunk = loadstring(source)
            if type(chunk) == "function" then
                return chunk()
            end
        end
        return nil
    end)
    if ok2 and type(bar2) == "table" and type(bar2.Notify) == "function" then
        return bar2
    end

    return nil
end

local function parseArgs(name, desc, callback)
    if typeof(name) == "table" then
        local d = name
        return {
            Title = d.Title or d.Name or d.Text or "Untitled",
            Description = d.Description or d.Desc or "",
            Callback = d.Callback or d.CallBack or callback,
            Default = d.Default,
            Options = d.Options,
            Min = d.Min,
            Max = d.Max,
            Placeholder = d.Placeholder,
            Flag = d.Flag,
            Multi = d.Multi == true,
            Key = d.Key,
            Color = d.Color
        }
    end

    return {
        Title = tostring(name or "Untitled"),
        Description = tostring(desc or ""),
        Callback = callback
    }
end

local function createInfoCard(parent, theme, title, desc, height)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, height or 48)
    frame.BackgroundColor3 = theme.SurfaceSoft
    frame.BorderSizePixel = 0
    frame.Parent = parent
    applyCorner(frame, 8)

    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.Position = UDim2.fromOffset(10, 4)
    titleLabel.Size = UDim2.new(1, -16, 0, 19)
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 13
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.TextColor3 = theme.Text
    titleLabel.Text = title or "Title"
    titleLabel.Parent = frame

    local descLabel = Instance.new("TextLabel")
    descLabel.BackgroundTransparency = 1
    descLabel.Position = UDim2.fromOffset(10, 21)
    descLabel.Size = UDim2.new(1, -16, 0, 18)
    descLabel.Font = Enum.Font.Gotham
    descLabel.TextSize = 12
    descLabel.TextXAlignment = Enum.TextXAlignment.Left
    descLabel.TextColor3 = theme.SubText
    descLabel.Text = desc or ""
    descLabel.Parent = frame

    return frame, titleLabel, descLabel
end

function EllaLibrary.CreateLib(windowTitle, themeName, options)
    options = options or {}

    local self = setmetatable({}, EllaLibrary)
    self.ThemeName = themeName or "DarkTheme"
    self.Theme = shallowCopy(DEFAULT_THEME)
    self.Config = {
        Enabled = options.ConfigurationSaving and options.ConfigurationSaving.Enabled == true,
        Folder = options.ConfigurationSaving and options.ConfigurationSaving.FolderName or "EllaHub",
        File = options.ConfigurationSaving and options.ConfigurationSaving.FileName or "ui_config.json"
    }
    self.Notifier = options.Notifier or loadFloatingBar()
    self.ToggleKey = options.ToggleKey or Enum.KeyCode.RightShift
    self.Tabs = {}
    self.ActiveTab = nil
    self.Flags = {}
    self.FlagSetters = {}
    self.ThemeObjects = {}
    self.Connections = {}
    self.LastOpenedDropdown = nil
    self.MainVisible = true
    self.LayoutMode = options.LayoutMode or (options.TopDock and "TopDock" or "Window")
    self.Draggable = options.Draggable
    self.TopOffset = tonumber(options.TopOffset) or 10
    self.WindowedSize = options.WindowedSize or UDim2.fromOffset(760, 490)
    self.TopDockSize = options.TopDockSize or UDim2.new(1, -80, 0, 360)
    if self.Draggable == nil then
        self.Draggable = self.LayoutMode ~= "TopDock"
    end

    if typeof(options.Theme) == "table" then
        for k, v in pairs(options.Theme) do
            if self.Theme[k] ~= nil then
                self.Theme[k] = v
            end
        end
    end
    if typeof(options.AccentColor) == "Color3" then
        self.Theme.Accent = options.AccentColor
    end

    local gui = Instance.new("ScreenGui")
    gui.Name = "EllaUI"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    gui.Parent = resolveGuiParent()
    safeProtectGui(gui)
    self.Gui = gui

    local root = Instance.new("Frame")
    if options.Size then
        root.Size = options.Size
    else
        root.Size = self.LayoutMode == "TopDock" and self.TopDockSize or self.WindowedSize
    end
    if self.LayoutMode == "TopDock" then
        root.AnchorPoint = Vector2.new(0.5, 0)
        root.Position = options.Position or UDim2.new(0.5, 0, 0, self.TopOffset)
    else
        root.Position = options.Position or UDim2.new(0.5, -380, 0.5, -245)
    end
    root.BackgroundColor3 = self.Theme.Background
    root.BorderSizePixel = 0
    root.Parent = gui
    applyCorner(root, 12)
    self.Root = root

    local shadow = Instance.new("ImageLabel")
    shadow.BackgroundTransparency = 1
    shadow.Size = UDim2.new(1, 60, 1, 60)
    shadow.Position = UDim2.fromOffset(-30, -30)
    shadow.Image = "rbxassetid://6014261993"
    shadow.ImageTransparency = 0.62
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(49, 49, 450, 450)
    shadow.ZIndex = 0
    shadow.Parent = root

    local top = Instance.new("Frame")
    top.Size = UDim2.new(1, 0, 0, 46)
    top.BackgroundColor3 = self.Theme.TopBar
    top.BorderSizePixel = 0
    top.Parent = root
    applyCorner(top, 12)
    self.Top = top

    local title = Instance.new("TextLabel")
    title.BackgroundTransparency = 1
    title.Position = UDim2.fromOffset(14, 0)
    title.Size = UDim2.new(1, -130, 1, 0)
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.TextSize = 14
    title.TextColor3 = self.Theme.Text
    title.Text = windowTitle or "Ella UI"
    title.Parent = top
    self.WindowTitle = title

    local closeButton = Instance.new("TextButton")
    closeButton.Size = UDim2.fromOffset(28, 28)
    closeButton.Position = UDim2.new(1, -36, 0.5, -14)
    closeButton.BackgroundColor3 = self.Theme.Surface
    closeButton.Text = "X"
    closeButton.Font = Enum.Font.GothamBold
    closeButton.TextSize = 13
    closeButton.TextColor3 = self.Theme.Text
    closeButton.BorderSizePixel = 0
    closeButton.AutoButtonColor = false
    closeButton.Parent = top
