function EllaLibrary.CreateLib(windowTitle, _, options)
    options = options or {}
    local self = setmetatable({}, EllaLibrary)

    self.Theme     = shallowCopy(DEFAULT_THEME)
    self.Config    = {
        Enabled = options.ConfigurationSaving and options.ConfigurationSaving.Enabled == true,
        Folder  = (options.ConfigurationSaving and options.ConfigurationSaving.FolderName) or "EllaHub",
        File    = (options.ConfigurationSaving and options.ConfigurationSaving.FileName)   or "ui_config.json",
    }
    self.Notifier  = options.Notifier or loadFloatingBar()
    self.ToggleKey = options.ToggleKey or Enum.KeyCode.RightShift
    self.Tabs      = {}
    self.ActiveTab = nil
    self.Flags     = {}
    self.FlagSetters       = {}
    self.ThemeObjects      = {}
    self.Connections       = {}
    self.LastOpenedDropdown = nil
    self.MainVisible       = true
    self.LayoutMode        = options.LayoutMode or (options.TopDock and "TopDock" or "Window")
    self.TopOffset         = tonumber(options.TopOffset) or 10
    self.WindowedSize      = options.WindowedSize or UDim2.fromOffset(820, 520)
    self.TopDockSize       = options.TopDockSize  or UDim2.new(1, -80, 0, 380)
    self.Draggable         = options.Draggable
    if self.Draggable == nil then self.Draggable = self.LayoutMode ~= "TopDock" end

    if typeof(options.Theme) == "table" then
        for k,v in pairs(options.Theme) do
            if self.Theme[k] ~= nil then self.Theme[k] = v end
        end
    end
    if typeof(options.AccentColor) == "Color3" then self.Theme.Accent = options.AccentColor end

    -- ── ScreenGui ──────────────────────────────────────────
    local gui = Instance.new("ScreenGui")
    gui.Name           = "EllaUI"
    gui.ResetOnSpawn   = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    gui.Parent         = resolveGuiParent()
    safeProtect(gui)
    self.Gui = gui

    -- ── Root ───────────────────────────────────────────────
    local root = Instance.new("Frame")
    root.Size             = options.Size or (self.LayoutMode=="TopDock" and self.TopDockSize or self.WindowedSize)
    root.BackgroundColor3 = self.Theme.Background
    root.BorderSizePixel  = 0
    root.Parent           = gui
    corner(root, 14)
    stroke(root, self.Theme.Border, 0, 1)
    if self.LayoutMode == "TopDock" then
        root.AnchorPoint = Vector2.new(0.5, 0)
        root.Position    = options.Position or UDim2.new(0.5,0,0,self.TopOffset)
    else
        root.Position = options.Position or UDim2.new(0.5,-410,0.5,-260)
    end

    -- Subtiler Glow-Schatten
    local shadow = Instance.new("ImageLabel")
    shadow.BackgroundTransparency = 1
    shadow.Size       = UDim2.new(1,80,1,80)
    shadow.Position   = UDim2.fromOffset(-40,-40)
    shadow.Image      = "rbxassetid://6014261993"
    shadow.ImageColor3 = self.Theme.Accent
    shadow.ImageTransparency = 0.88
    shadow.ScaleType  = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(49,49,450,450)
    shadow.ZIndex     = 0
    shadow.Parent     = root
    self.Root = root

    -- ── TopBar ─────────────────────────────────────────────
    local topbar = Instance.new("Frame")
    topbar.Size             = UDim2.new(1,0,0,48)
    topbar.BackgroundColor3 = self.Theme.Background
    topbar.BorderSizePixel  = 0
    topbar.ZIndex           = 2
    topbar.Parent           = root
    corner(topbar, 14)

    -- Trennlinie unter Topbar
    local topDivider = Instance.new("Frame")
    topDivider.Size             = UDim2.new(1,-240,0,1)
    topDivider.Position         = UDim2.new(0,230,0,47)
    topDivider.BackgroundColor3 = self.Theme.Border
    topDivider.BorderSizePixel  = 0
    topDivider.Parent           = root

    -- Logo-Dot (Accent-Farbe)
    local logoDot = Instance.new("Frame")
    logoDot.Size             = UDim2.fromOffset(8,8)
    logoDot.Position         = UDim2.fromOffset(16,20)
    logoDot.BackgroundColor3 = self.Theme.Accent
    logoDot.BorderSizePixel  = 0
    logoDot.Parent           = topbar
    corner(logoDot, 999)

    -- Titel
    local titleLbl = Instance.new("TextLabel")
    titleLbl.BackgroundTransparency = 1
    titleLbl.Position       = UDim2.fromOffset(32, 0)
    titleLbl.Size           = UDim2.new(0, 200, 1, 0)
    titleLbl.Font           = Enum.Font.GothamBold
    titleLbl.TextSize       = 14
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.TextColor3     = self.Theme.Text
    titleLbl.Text           = windowTitle or "Ella UI"
    titleLbl.Parent         = topbar
    self.WindowTitle = titleLbl

    -- Version-Badge
    local badge = Instance.new("TextLabel")
    badge.BackgroundColor3   = self.Theme.AccentDim
    badge.Size               = UDim2.fromOffset(28, 16)
    badge.Position           = UDim2.fromOffset(32 + titleLbl.TextBounds.X + 8, 16)
    badge.Font               = Enum.Font.GothamBold
    badge.TextSize           = 9
    badge.TextColor3         = self.Theme.AccentGlow
    badge.Text               = "v3"
    badge.BorderSizePixel    = 0
    badge.ZIndex             = 3
    badge.Parent             = topbar
    corner(badge, 4)

    -- Minimize / Close
    local function makeIconBtn(text, xOff)
        local b = Instance.new("TextButton")
        b.Size              = UDim2.fromOffset(28, 28)
        b.Position          = UDim2.new(1, xOff, 0.5, -14)
        b.BackgroundColor3  = self.Theme.Surface
        b.Text              = text
        b.Font              = Enum.Font.GothamBold
        b.TextSize          = 13
        b.TextColor3        = self.Theme.SubText
        b.AutoButtonColor   = false
        b.BorderSizePixel   = 0
        b.Parent            = topbar
        corner(b, 7)
        stroke(b, self.Theme.Border, 0, 1)
        hoverEffect(b, self.Theme.Surface, self.Theme.SurfaceHover)
        return b
    end

    local closeBtn    = makeIconBtn("✕", -10)
    local minimizeBtn = makeIconBtn("—", -44)

    -- ── Sidebar ────────────────────────────────────────────
    local sidebar = Instance.new("Frame")
    sidebar.Size             = UDim2.new(0, 195, 1, -58)
    sidebar.Position         = UDim2.fromOffset(10, 52)
    sidebar.BackgroundColor3 = self.Theme.Sidebar
    sidebar.BorderSizePixel  = 0
    sidebar.Parent           = root
    corner(sidebar, 10)
    stroke(sidebar, self.Theme.Border, 0, 1)

    local sideScroll = Instance.new("ScrollingFrame")
    sideScroll.Size                 = UDim2.new(1, -8, 1, -8)
    sideScroll.Position             = UDim2.fromOffset(4, 4)
    sideScroll.BackgroundTransparency = 1
    sideScroll.BorderSizePixel      = 0
    sideScroll.ScrollBarThickness   = 2
    sideScroll.ScrollBarImageColor3 = self.Theme.Muted
    sideScroll.CanvasSize           = UDim2.new(0,0,0,0)
    sideScroll.Parent               = sidebar
    self.TabList = sideScroll

    local sideLayout = Instance.new("UIListLayout")
    sideLayout.Padding        = UDim.new(0, 4)
    sideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    sideLayout.Parent         = sideScroll
    padding(sideScroll, 4)

    table.insert(self.Connections, sideLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        sideScroll.CanvasSize = UDim2.new(0,0,0,sideLayout.AbsoluteContentSize.Y+8)
    end))

    -- ── Content-Bereich ────────────────────────────────────
    local content = Instance.new("Frame")
    content.Size             = UDim2.new(1,-215,1,-58)
    content.Position         = UDim2.fromOffset(212, 52)
    content.BackgroundTransparency = 1
    content.BorderSizePixel  = 0
    content.Parent           = root
    self.Pages = content

    -- ── Drag-Logic ─────────────────────────────────────────
    local dragging, dragStart, startPos = false, nil, nil
    table.insert(self.Connections, topbar.InputBegan:Connect(function(input)
        if not self.Draggable then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging=true; dragStart=input.Position; startPos=root.Position
        end
    end))
    table.insert(self.Connections, topbar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end
    end))
    table.insert(self.Connections, UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local d = input.Position - dragStart
            root.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
        end
    end))

    -- ── Keybinds & Toggle ──────────────────────────────────
    table.insert(self.Connections, UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == self.ToggleKey then self:Toggle() return end
        for _, entry in pairs(self.Flags) do
            if entry and entry.Type=="Keybind" and entry.Key==input.KeyCode and type(entry.Callback)=="function" then
                pcall(entry.Callback, input.KeyCode)
            end
        end
    end))

    table.insert(self.Connections, closeBtn.MouseButton1Click:Connect(function() self:Destroy() end))
    table.insert(self.Connections, minimizeBtn.MouseButton1Click:Connect(function() self:Toggle() end))

    -- ── Public API ─────────────────────────────────────────

    function self:Toggle()
        self.MainVisible = not self.MainVisible
        root.Visible = self.MainVisible
    end

    function self:SetToggleKey(kc)
        if typeof(kc)=="EnumItem" and kc.EnumType==Enum.KeyCode then self.ToggleKey=kc end
    end

    function self:Notify(a, b, c)
        if not self.Notifier then return end
        if type(a)=="table" then self.Notifier:Notify(a)
        else self.Notifier:Notify({Title=tostring(a or ""),Content=tostring(b or ""),Duration=c}) end
    end

    function self:SetFlag(flag, value, skip)
        if not flag then return end
        local slot = self.Flags[flag]
        if slot then
            slot.Value = value
            if self.FlagSetters[flag] then self.FlagSetters[flag](value, skip==true) end
        else
            self.Flags[flag] = {Value=value,Type="Raw"}
        end
    end

    function self:GetFlag(flag)
        local s=self.Flags[flag]; return s and s.Value or nil
    end

    function self:UpdateTheme(t)
        if typeof(t)~="table" then return end
        for k,v in pairs(t) do
            if self.Theme[k]~=nil and typeof(v)=="Color3" then self.Theme[k]=v end
        end
        for inst, token in pairs(self.ThemeObjects) do
            if inst and inst.Parent and self.Theme[token] then
                if inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox") then
                    if token=="Text" or token=="SubText" then inst.TextColor3=self.Theme[token]
                    else inst.BackgroundColor3=self.Theme[token] end
                elseif inst:IsA("UIStroke") then inst.Color=self.Theme[token]
                elseif inst:IsA("Frame") or inst:IsA("ScrollingFrame") then inst.BackgroundColor3=self.Theme[token] end
            end
        end
    end

    function self:SaveConfig()
        if not self.Config.Enabled then return false,"disabled" end
        if type(writefile)~="function" then return false,"writefile unavailable" end
        if type(makefolder)=="function" and type(isfolder)=="function" and not isfolder(self.Config.Folder) then
            pcall(makefolder, self.Config.Folder)
        end
        local data={}
        for name,entry in pairs(self.Flags) do
            if entry and entry.Value~=nil and entry.Type~="Keybind" then
                local v=entry.Value
                if typeof(v)=="Color3" then
                    data[name]={__type="Color3",R=math.floor(v.R*255+.5),G=math.floor(v.G*255+.5),B=math.floor(v.B*255+.5)}
                else data[name]=v end
            end
        end
        local ok,err=pcall(writefile,self.Config.Folder.."/"..self.Config.File,HttpService:JSONEncode(data))
        return ok,err
    end

    function self:LoadConfig()
        if not self.Config.Enabled then return false,"disabled" end
        if type(readfile)~="function" or type(isfile)~="function" then return false,"unavailable" end
        local path=self.Config.Folder.."/"..self.Config.File
        if not isfile(path) then return false,"missing" end
        local ok,raw=pcall(readfile,path)
        if not ok then return false,raw end
        local ok2,data=pcall(function() return HttpService:JSONDecode(raw) end)
        if not ok2 or type(data)~="table" then return false,"bad json" end
        for flag,value in pairs(data) do
            if type(value)=="table" and value.__type=="Color3" then
                value=Color3.fromRGB(value.R or 0,value.G or 0,value.B or 0)
            end
            self:SetFlag(flag,value)
        end
        return true
    end

    function self:Destroy()
        for _,c in ipairs(self.Connections) do pcall(function() c:Disconnect() end) end
        self.Connections={}
        if self.Gui then self.Gui:Destroy() end
    end

    -- ── Flag-Registrierung ─────────────────────────────────
    local function registerFlag(flag, vtype, cb, setter, default)
        if not flag then return end
        self.Flags[flag] = {Type=vtype, Value=default, Callback=cb}
        self.FlagSetters[flag] = function(v, skip)
            setter(v, skip)
            self.Flags[flag].Value = v
            if not skip and type(cb)=="function" then cb(v) end
        end
    end

    -- ── Tab-Button-Builder ─────────────────────────────────
    local function makeTabBtn(text, icon)
        local btn = Instance.new("TextButton")
        btn.Size            = UDim2.new(1,-8,0,38)
        btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
        btn.BackgroundTransparency = 1
        btn.Text            = ""
        btn.AutoButtonColor = false
        btn.BorderSizePixel = 0
        btn.Parent          = sideScroll
        corner(btn, 8)

        -- Hover-BG
        local hoverBg = Instance.new("Frame")
        hoverBg.Size             = UDim2.fromScale(1,1)
        hoverBg.BackgroundColor3 = self.Theme.SurfaceHover
        hoverBg.BackgroundTransparency = 1
        hoverBg.BorderSizePixel  = 0
        hoverBg.Parent           = btn
        corner(hoverBg, 8)

        -- Active-BG
        local activeBg = Instance.new("Frame")
        activeBg.Size             = UDim2.fromScale(1,1)
        activeBg.BackgroundColor3 = self.Theme.AccentDim
        activeBg.BackgroundTransparency = 1
        activeBg.BorderSizePixel  = 0
        activeBg.Parent           = btn
        corner(activeBg, 8)

        -- Linker Accent-Streifen
        local bar = Instance.new("Frame")
        bar.Size             = UDim2.new(0,3,0.5,0)
        bar.Position         = UDim2.new(0,0,0.25,0)
        bar.BackgroundColor3 = self.Theme.Accent
        bar.BorderSizePixel  = 0
        bar.BackgroundTransparency = 1
        bar.Parent           = btn
        corner(bar, 999)

        -- Icon
        local iconLbl = Instance.new("TextLabel")
        iconLbl.BackgroundTransparency = 1
        iconLbl.Size            = UDim2.fromOffset(18, 38)
        iconLbl.Position        = UDim2.fromOffset(10, 0)
        iconLbl.Font            = Enum.Font.GothamBold
        iconLbl.TextSize        = 13
        iconLbl.TextColor3      = self.Theme.Muted
        iconLbl.Text            = icon or "›"
        iconLbl.Parent          = btn

        -- Label
        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.Position        = UDim2.fromOffset(32, 0)
        lbl.Size            = UDim2.new(1,-36,1,0)
        lbl.Font            = Enum.Font.Gotham
        lbl.TextSize        = 13
        lbl.TextXAlignment  = Enum.TextXAlignment.Left
        lbl.TextColor3      = self.Theme.SubText
        lbl.Text            = text or "Tab"
        lbl.Parent          = btn

        btn.MouseEnter:Connect(function()
            tween(hoverBg, FAST, {BackgroundTransparency=0.85})
        end)
        btn.MouseLeave:Connect(function()
            tween(hoverBg, FAST, {BackgroundTransparency=1})
        end)

        local function setActive(active)
            if active then
                tween(activeBg, FAST, {BackgroundTransparency=0.82})
                tween(bar, FAST, {BackgroundTransparency=0})
                tween(lbl, FAST, {TextColor3=self.Theme.Text})
                tween(iconLbl, FAST, {TextColor3=self.Theme.Accent})
                lbl.Font = Enum.Font.GothamBold
            else
                tween(activeBg, FAST, {BackgroundTransparency=1})
                tween(bar, FAST, {BackgroundTransparency=1})
                tween(lbl, FAST, {TextColor3=self.Theme.SubText})
                tween(iconLbl, FAST, {TextColor3=self.Theme.Muted})
                lbl.Font = Enum.Font.Gotham
            end
        end

        return btn, lbl, setActive
    end

    -- ════════════════════════════════════════════════════
