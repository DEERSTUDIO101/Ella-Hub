            function section:NewToggle(name, desc, callback)
                local data = parseArgs(name, desc, callback)
                local state = data.Default == true
                local f = createInfoCard(controls, library.Theme, data.Title, data.Description, 46)

                local toggle = Instance.new("TextButton")
                toggle.Size = UDim2.fromOffset(52, 24)
                toggle.Position = UDim2.new(1, -62, 0.5, -12)
                toggle.BackgroundColor3 = Color3.fromRGB(35, 37, 48)
                toggle.Text = ""
                toggle.AutoButtonColor = false
                toggle.BorderSizePixel = 0
                toggle.Parent = f
                applyCorner(toggle, 999)

                local dot = Instance.new("Frame")
                dot.Size = UDim2.fromOffset(18, 18)
                dot.Position = UDim2.fromOffset(3, 3)
                dot.BackgroundColor3 = Color3.fromRGB(220, 224, 244)
                dot.BorderSizePixel = 0
                dot.Parent = toggle
                applyCorner(dot, 999)

                local function setState(newState, skipCallback)
                    state = newState == true
                    TweenService:Create(toggle, TweenInfo.new(0.2), {
