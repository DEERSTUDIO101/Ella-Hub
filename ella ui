            -- ── SLIDER ────────────────────────────────────
            function section:NewSlider(name, desc, max, min, cb)
                local data = parseArgs(name, desc, cb)
                data.Max = data.Max or tonumber(max) or 100
                data.Min = data.Min or tonumber(min) or 0
                local value = data.Default or data.Min
                local draggingSlider = false

                local row, titleL, descL = makeRow(controls, lib.Theme, data.Title, data.Description, 62)
                row.Size = UDim2.new(1,0,0,62)

                -- Wert-Badge rechts
                local valBadge = Instance.new("TextLabel")
                valBadge.Size             = UDim2.fromOffset(48,20)
                valBadge.Position         = UDim2.new(1,-56,0,15)
                valBadge.BackgroundColor3 = lib.Theme.Input
                valBadge.Font             = Enum.Font.GothamBold
                valBadge.TextSize         = 11
                valBadge.TextColor3       = lib.Theme.Accent
                valBadge.Text             = tostring(value)
                valBadge.BorderSizePixel  = 0
                valBadge.Parent           = row
                corner(valBadge, 5)

                -- Slider-Track
                local track = Instance.new("Frame")
                track.Size             = UDim2.new(1,-16,0,6)
                track.Position         = UDim2.new(0,8,1,-14)
                track.BackgroundColor3 = lib.Theme.Input
                track.BorderSizePixel  = 0
                track.Parent           = row
                corner(track, 999)

                -- Fill
                local fill = Instance.new("Frame")
                fill.Size             = UDim2.new(0,0,1,0)
                fill.BackgroundColor3 = lib.Theme.Accent
                fill.BorderSizePixel  = 0
                fill.Parent           = track
                corner(fill, 999)

                -- Gradient auf dem Fill
                gradient(fill,
                    lib.Theme.Accent,
                    lib.Theme.AccentGlow,
                    0
                )

                -- Knob
                local knob = Instance.new("Frame")
                knob.Size             = UDim2.fromOffset(14,14)
                knob.AnchorPoint      = Vector2.new(0.5,0.5)
                knob.Position         = UDim2.new(0,0,0.5,0)
                knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
                knob.BorderSizePixel  = 0
                knob.ZIndex           = 2
                knob.Parent           = track
                corner(knob, 999)
                stroke(knob, lib.Theme.Accent, 0, 2)

                local function setValue(v, skip)
                    v = math.clamp(tonumber(v) or data.Min, data.Min, data.Max)
                    value = math.floor(v+0.5)
                    local alpha = (value-data.Min)/math.max(data.Max-data.Min,1)
                    tween(fill, FAST, {Size=UDim2.new(alpha,0,1,0)})
                    tween(knob, FAST, {Position=UDim2.new(alpha,0,0.5,0)})
                    valBadge.Text = tostring(value)
                    if not skip and type(data.Callback)=="function" then data.Callback(value) end
                    if data.Flag and lib.Flags[data.Flag] then lib.Flags[data.Flag].Value=value end
                end

                local function fromX(x)
                    local alpha = math.clamp((x-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
                    setValue(data.Min+(data.Max-data.Min)*alpha, false)
                end

                table.insert(lib.Connections, track.InputBegan:Connect(function(input)
                    if input.UserInputType==Enum.UserInputType.MouseButton1 then
                        draggingSlider=true; fromX(input.Position.X)
                    end
                end))
                table.insert(lib.Connections, UserInputService.InputChanged:Connect(function(input)
                    if draggingSlider and input.UserInputType==Enum.UserInputType.MouseMovement then
                        fromX(input.Position.X)
                    end
                end))
                table.insert(lib.Connections, UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType==Enum.UserInputType.MouseButton1 then draggingSlider=false end
                end))

                if data.Flag then registerFlag(data.Flag,"Slider",data.Callback,setValue,value) end
                setValue(value, true)

                return {
                    Set = function(_,v,s) setValue(v,s==true) end,
                    Get = function() return value end,
                }
            end

            -- ── DROPDOWN ──────────────────────────────────
            function section:NewDropdown(name, desc, opts, cb)
                local data = parseArgs(name, desc, cb)
                data.Options = data.Options or opts or {}
                local selected = data.Multi and {} or (data.Default or nil)
                local isOpen = false

                local row, titleL, descL = makeRow(controls, lib.Theme, data.Title, data.Description, 50)

                local dropBtn = Instance.new("TextButton")
                dropBtn.Size             = UDim2.fromOffset(130,26)
                dropBtn.Position         = UDim2.new(1,-138,0.5,-13)
                dropBtn.BackgroundColor3 = lib.Theme.Input
                dropBtn.TextColor3       = lib.Theme.SubText
                dropBtn.Font             = Enum.Font.Gotham
                dropBtn.TextSize         = 11
                dropBtn.TextXAlignment   = Enum.TextXAlignment.Left
                dropBtn.Text             = "  " .. (selected or "Auswählen...")
                dropBtn.AutoButtonColor  = false
                dropBtn.BorderSizePixel  = 0
                dropBtn.Parent           = row
                corner(dropBtn, 6)
                stroke(dropBtn, lib.Theme.Border, 0, 1)

                local arrow = Instance.new("TextLabel")
                arrow.BackgroundTransparency = 1
                arrow.Size            = UDim2.fromOffset(16,26)
                arrow.Position        = UDim2.new(1,-18,0,0)
                arrow.Font            = Enum.Font.GothamBold
                arrow.TextSize        = 10
                arrow.TextColor3      = lib.Theme.Muted
                arrow.Text            = "▼"
                arrow.Parent          = dropBtn

                -- Dropdown-Liste (unter der Row, Z-overlay)
                local list = Instance.new("ScrollingFrame")
                list.Size                  = UDim2.new(0,130,0,0)
                list.Position              = UDim2.new(1,-138,1,4)
                list.BackgroundColor3      = lib.Theme.Surface
                list.BorderSizePixel       = 0
                list.ScrollBarThickness    = 2
                list.ScrollBarImageColor3  = lib.Theme.Muted
                list.ClipsDescendants      = true
                list.ZIndex                = 50
                list.Visible               = false
                list.Parent                = row
                corner(list, 8)
                stroke(list, lib.Theme.Border, 0, 1)

                local listLayout = Instance.new("UIListLayout")
                listLayout.Padding = UDim.new(0,3)
                listLayout.Parent  = list
                padding(list, 4)

                local function updateDisplay()
                    if data.Multi then
                        local keys={}
                        for k,v in pairs(selected) do if v then table.insert(keys,k) end end
                        dropBtn.Text = "  "..(#keys>0 and table.concat(keys,", ") or "Auswählen...")
                    else
                        dropBtn.Text = "  "..(selected or "Auswählen...")
                    end
                end

                local function fireCallback()
                    if type(data.Callback)=="function" then
                        if data.Multi then
                            local out={}
                            for k,v in pairs(selected) do if v then table.insert(out,k) end end
                            data.Callback(out)
                        else data.Callback(selected) end
                    end
                end

                local function setOpen(open)
                    isOpen = open
                    if open then
                        if lib.LastOpenedDropdown and lib.LastOpenedDropdown~=list then
                            lib.LastOpenedDropdown.Visible=false
                        end
                        list.Visible=true
                        local h=math.clamp(listLayout.AbsoluteContentSize.Y+12,0,150)
                        tween(list,FAST,{Size=UDim2.new(0,130,0,h)})
                        tween(arrow,FAST,{Rotation=180})
                        lib.LastOpenedDropdown=list
                    else
                        tween(list,FAST,{Size=UDim2.new(0,130,0,0)})
                        tween(arrow,FAST,{Rotation=0})
                        task.delay(0.15,function() if not isOpen then list.Visible=false end end)
                        if lib.LastOpenedDropdown==list then lib.LastOpenedDropdown=nil end
                    end
                end

                for _,opt in ipairs(data.Options) do
                    local item = Instance.new("TextButton")
                    item.Size             = UDim2.new(1,-8,0,26)
                    item.BackgroundColor3 = lib.Theme.SurfaceHover
                    item.BackgroundTransparency = 1
                    item.TextColor3       = lib.Theme.SubText
                    item.Font             = Enum.Font.Gotham
                    item.TextSize         = 11
                    item.TextXAlignment   = Enum.TextXAlignment.Left
                    item.Text             = "  "..tostring(opt)
                    item.AutoButtonColor  = false
                    item.BorderSizePixel  = 0
                    item.ZIndex           = 51
                    item.Parent           = list
                    corner(item, 5)

                    item.MouseEnter:Connect(function()
                        tween(item,FAST,{BackgroundTransparency=0, TextColor3=lib.Theme.Text})
                    end)
                    item.MouseLeave:Connect(function()
                        tween(item,FAST,{BackgroundTransparency=1, TextColor3=lib.Theme.SubText})
                    end)

                    table.insert(lib.Connections, item.MouseButton1Click:Connect(function()
                        if data.Multi then
                            selected[opt] = not selected[opt]
                        else
                            selected = opt
                            setOpen(false)
                        end
                        updateDisplay()
                        fireCallback()
                    end))
                end

                table.insert(lib.Connections, dropBtn.MouseButton1Click:Connect(function()
                    setOpen(not isOpen)
                end))

                if data.Flag then
                    registerFlag(data.Flag,"Dropdown",data.Callback,function(v)
                        selected=v; updateDisplay()
                    end, selected)
                end
                updateDisplay()

                return {
                    Set = function(_,v,s) selected=v updateDisplay() if not s and type(data.Callback)=="function" then fireCallback() end end,
                    Get = function() return selected end,
                }
            end

