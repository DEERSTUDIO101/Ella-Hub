            -- ── KEYBIND ───────────────────────────────────
            function section:NewKeybind(name, desc, defaultKey, cb)
                local data = parseArgs(name, desc, cb)
                data.Key = data.Key or defaultKey or Enum.KeyCode.Unknown
                local current = data.Key
                local listening = false

                local row = makeRow(controls, lib.Theme, data.Title, data.Description, 50)

                local bindBtn = Instance.new("TextButton")
                bindBtn.Size             = UDim2.fromOffset(90,26)
                bindBtn.Position         = UDim2.new(1,-98,0.5,-13)
                bindBtn.BackgroundColor3 = lib.Theme.Input
                bindBtn.TextColor3       = lib.Theme.Text
                bindBtn.Font             = Enum.Font.GothamBold
                bindBtn.TextSize         = 11
                bindBtn.Text             = current==Enum.KeyCode.Unknown and "Kein Key" or current.Name
                bindBtn.AutoButtonColor  = false
                bindBtn.BorderSizePixel  = 0
                bindBtn.Parent           = row
                corner(bindBtn, 6)
                stroke(bindBtn, lib.Theme.Border, 0, 1)

                local function setKey(kc, skip)
                    if typeof(kc)~="EnumItem" or kc.EnumType~=Enum.KeyCode then return end
                    current = kc
                    bindBtn.Text = kc==Enum.KeyCode.Unknown and "Kein Key" or kc.Name
                    tween(bindBtn, FAST, {BackgroundColor3=lib.Theme.Input, TextColor3=lib.Theme.Text})
                    if data.Flag and lib.Flags[data.Flag] then lib.Flags[data.Flag].Value=current end
                    if not skip and type(data.Callback)=="function" then data.Callback(current) end
                end

                table.insert(lib.Connections, bindBtn.MouseButton1Click:Connect(function()
                    listening=true
                    bindBtn.Text="Drücken..."
                    tween(bindBtn,FAST,{BackgroundColor3=lib.Theme.AccentDim,TextColor3=lib.Theme.AccentGlow})
                end))
                table.insert(lib.Connections, UserInputService.InputBegan:Connect(function(input,proc)
                    if proc or not listening then return end
                    if input.UserInputType==Enum.UserInputType.Keyboard then
                        listening=false; setKey(input.KeyCode, false)
                    end
                end))

                if data.Flag then registerFlag(data.Flag,"Keybind",data.Callback,setKey,current) end
                lib.Flags[data.Flag or ("__kb_"..current.Name)] = {Type="Keybind",Key=current,Callback=data.Callback,Value=current}

                return {
                    Set = function(_,kc,s) setKey(kc,s==true) end,
                    Get = function() return current end,
                }
            end

            -- ── COLORPICKER ───────────────────────────────
            function section:NewColorPicker(name, desc, cb)
                local data = parseArgs(name, desc, cb)
                local value = data.Color or data.Default or lib.Theme.Accent
                local row = makeRow(controls, lib.Theme, data.Title, data.Description, 50)

                local preview = Instance.new("Frame")
                preview.Size             = UDim2.fromOffset(36,22)
                preview.Position         = UDim2.new(1,-44,0.5,-11)
                preview.BackgroundColor3 = value
                preview.BorderSizePixel  = 0
                preview.Parent           = row
                corner(preview, 6)
                stroke(preview, lib.Theme.Border, 0, 1)

                -- Einfache RGB-Boxen unterhalb (aufklappbar)
                local pickerOpen = false
                local pickerFrame = Instance.new("Frame")
                pickerFrame.Size             = UDim2.new(1,0,0,36)
                pickerFrame.BackgroundColor3 = lib.Theme.Input
                pickerFrame.BorderSizePixel  = 0
                pickerFrame.Visible          = false
                pickerFrame.Parent           = row
                -- wird dynamisch positioniert nach Toggle
                corner(pickerFrame, 6)

                local function setColor(c, skip)
                    if typeof(c)~="Color3" then return end
                    value = c
                    tween(preview, FAST, {BackgroundColor3=c})
                    if data.Flag and lib.Flags[data.Flag] then lib.Flags[data.Flag].Value=c end
                    if not skip and type(data.Callback)=="function" then data.Callback(c) end
                end

                local rBox,gBox,bBox = Instance.new("TextBox"),Instance.new("TextBox"),Instance.new("TextBox")
                local labels = {"R","G","B"}
                for i,box in ipairs({rBox,gBox,bBox}) do
                    box.Size             = UDim2.new(0.33,-4,0,26)
                    box.Position         = UDim2.new((i-1)*0.333,i==1 and 4 or 2,0,5)
                    box.BackgroundColor3 = lib.Theme.Surface
                    box.TextColor3       = lib.Theme.Text
                    box.PlaceholderColor3 = lib.Theme.Muted
                    box.PlaceholderText  = labels[i]
                    box.Font             = Enum.Font.GothamBold
                    box.TextSize         = 11
                    box.BorderSizePixel  = 0
                    box.ClearTextOnFocus = false
                    box.Parent           = pickerFrame
                    corner(box,5)
                    box.FocusLost:Connect(function()
                        local r=math.clamp(tonumber(rBox.Text) or 255,0,255)
                        local g=math.clamp(tonumber(gBox.Text) or 255,0,255)
                        local b=math.clamp(tonumber(bBox.Text) or 255,0,255)
                        setColor(Color3.fromRGB(r,g,b),false)
                    end)
                end

                local function syncBoxes()
                    rBox.Text = tostring(math.floor(value.R*255+.5))
                    gBox.Text = tostring(math.floor(value.G*255+.5))
                    bBox.Text = tostring(math.floor(value.B*255+.5))
                end
                syncBoxes()

                local pickerHitbox = Instance.new("TextButton")
                pickerHitbox.Size              = UDim2.fromOffset(36,22)
                pickerHitbox.Position          = UDim2.new(1,-44,0.5,-11)
                pickerHitbox.BackgroundTransparency = 1
                pickerHitbox.Text              = ""
                pickerHitbox.Parent            = row

                table.insert(lib.Connections, pickerHitbox.MouseButton1Click:Connect(function()
                    pickerOpen = not pickerOpen
                    pickerFrame.Visible = pickerOpen
                    if pickerOpen then
                        pickerFrame.Position = UDim2.new(0,8,1,4)
                        row.Size = UDim2.new(1,0,0,94)
                        syncBoxes()
                    else
                        row.Size = UDim2.new(1,0,0,50)
                    end
                end))

                if data.Flag then registerFlag(data.Flag,"ColorPicker",data.Callback,setColor,value) end

                return {
                    Set = function(_,c,s) setColor(c,s==true); syncBoxes() end,
                    Get = function() return value end,
                }
            end

            -- ── LABEL ─────────────────────────────────────
            function section:NewLabel(text)
                local f = Instance.new("Frame")
                f.Size             = UDim2.new(1,0,0,32)
                f.BackgroundColor3 = lib.Theme.Input
                f.BorderSizePixel  = 0
                f.Parent           = controls
                corner(f, 7)

                local l = Instance.new("TextLabel")
                l.BackgroundTransparency = 1
                l.Size          = UDim2.new(1,-16,1,0)
                l.Position      = UDim2.fromOffset(8,0)
                l.Font          = Enum.Font.Gotham
                l.TextSize      = 12
                l.TextColor3    = lib.Theme.SubText
                l.TextXAlignment = Enum.TextXAlignment.Left
                l.Text          = tostring(text or "")
                l.Parent        = f

                return {
                    UpdateLabel = function(_,t) l.Text=tostring(t or "") end,
                }
            end

            -- ── PARAGRAPH ─────────────────────────────────
            function section:NewParagraph(t, body)
                local f = Instance.new("Frame")
                f.Size             = UDim2.new(1,0,0,60)
                f.BackgroundColor3 = lib.Theme.Input
                f.BorderSizePixel  = 0
                f.Parent           = controls
                corner(f, 7)
                padding(f,nil,10,10,6,6)

                local tl = Instance.new("TextLabel")
                tl.BackgroundTransparency = 1
                tl.Size         = UDim2.new(1,0,0,16)
                tl.Font         = Enum.Font.GothamBold
                tl.TextSize     = 12
                tl.TextColor3   = lib.Theme.Text
                tl.TextXAlignment = Enum.TextXAlignment.Left
                tl.Text         = tostring(t or "")
                tl.Parent       = f

                local bl = Instance.new("TextLabel")
                bl.BackgroundTransparency = 1
                bl.Size         = UDim2.new(1,0,0,32)
                bl.Position     = UDim2.fromOffset(0,18)
                bl.Font         = Enum.Font.Gotham
                bl.TextSize     = 11
                bl.TextColor3   = lib.Theme.SubText
                bl.TextXAlignment = Enum.TextXAlignment.Left
                bl.TextWrapped  = true
                bl.Text         = tostring(body or "")
                bl.Parent       = f

                return {Frame=f,Title=tl,Content=bl}
            end

            return section
        end -- NewSection

        return tab
    end -- NewTab

    return self
end -- CreateLib

-- ══════════════════════════════════════════════════════════
--  CreateTopPrompt  (Auth-Screen)
-- ══════════════════════════════════════════════════════════
function EllaLibrary.CreateTopPrompt(options)
    options = options or {}
    local TW = TweenService

    local gui = Instance.new("ScreenGui")
    gui.Name="EllaTopPrompt"; gui.ResetOnSpawn=false
    gui.IgnoreGuiInset=true; gui.ZIndexBehavior=Enum.ZIndexBehavior.Global
    gui.Parent = resolveGuiParent()
    safeProtect(gui)

    local holder = Instance.new("Frame")
    holder.Size=UDim2.fromOffset(380,148)
    holder.AnchorPoint=Vector2.new(0.5,0)
    holder.Position=UDim2.new(0.5,0,0,-200)
    holder.BackgroundColor3=Color3.fromRGB(14,16,22)
    holder.BorderSizePixel=0
    holder.Parent=gui
    corner(holder,14)
    stroke(holder,Color3.fromRGB(40,44,62),0,1)

    local accent=Instance.new("Frame")
    accent.Size=UDim2.new(1,0,0,3)
    accent.BackgroundColor3=DEFAULT_THEME.Accent
    accent.BorderSizePixel=0; accent.Parent=holder
    corner(accent,14)
    gradient(accent,DEFAULT_THEME.Accent,DEFAULT_THEME.AccentGlow,0)

    local logo=Instance.new("Frame")
    logo.Size=UDim2.fromOffset(36,36); logo.Position=UDim2.fromOffset(14,16)
    logo.BackgroundColor3=DEFAULT_THEME.AccentDim; logo.BorderSizePixel=0; logo.Parent=holder
    corner(logo,9)
    local logoIcon=Instance.new("TextLabel")
    logoIcon.BackgroundTransparency=1; logoIcon.Size=UDim2.fromScale(1,1)
    logoIcon.Font=Enum.Font.GothamBold; logoIcon.TextSize=16
    logoIcon.TextColor3=DEFAULT_THEME.AccentGlow; logoIcon.Text="E"; logoIcon.Parent=logo

    local title=Instance.new("TextLabel")
    title.BackgroundTransparency=1; title.Position=UDim2.fromOffset(58,16)
    title.Size=UDim2.new(1,-200,0,20); title.Font=Enum.Font.GothamBold
    title.TextSize=16; title.TextXAlignment=Enum.TextXAlignment.Left
    title.TextColor3=Color3.fromRGB(240,244,255)
    title.Text=options.Title or "Ella Hub"; title.Parent=holder

    local sub=Instance.new("TextLabel")
    sub.BackgroundTransparency=1; sub.Position=UDim2.fromOffset(58,36)
    sub.Size=UDim2.new(1,-200,0,14); sub.Font=Enum.Font.Gotham
    sub.TextSize=11; sub.TextXAlignment=Enum.TextXAlignment.Left
    sub.TextColor3=Color3.fromRGB(120,132,165)
    sub.Text=options.Subtitle or "Authentication required"; sub.Parent=holder

    -- Auto-Execute Toggle
    local autoExec = options.AutoExecute==true
    local autoLbl=Instance.new("TextLabel")
    autoLbl.BackgroundTransparency=1; autoLbl.Position=UDim2.new(1,-130,0,20)
    autoLbl.Size=UDim2.fromOffset(90,14); autoLbl.Font=Enum.Font.Gotham
    autoLbl.TextSize=10; autoLbl.TextXAlignment=Enum.TextXAlignment.Right
    autoLbl.TextColor3=Color3.fromRGB(100,112,145); autoLbl.Text="Auto Execute"; autoLbl.Parent=holder

    local tgl=Instance.new("TextButton"); tgl.Size=UDim2.fromOffset(28,15)
    tgl.Position=UDim2.new(1,-32,0,20); tgl.BackgroundColor3=Color3.fromRGB(30,34,50)
    tgl.Text=""; tgl.AutoButtonColor=false; tgl.BorderSizePixel=0; tgl.Parent=holder
    corner(tgl,999)
    local tglDot=Instance.new("Frame"); tglDot.Size=UDim2.fromOffset(11,11)
    tglDot.Position=UDim2.fromOffset(2,2); tglDot.BackgroundColor3=Color3.fromRGB(200,205,220)
    tglDot.BorderSizePixel=0; tglDot.Parent=tgl; corner(tglDot,999)

    local keyBox=Instance.new("TextBox"); keyBox.Size=UDim2.new(1,-24,0,30)
    keyBox.Position=UDim2.fromOffset(12,62); keyBox.BackgroundColor3=Color3.fromRGB(10,12,18)
    keyBox.TextColor3=Color3.fromRGB(220,226,245); keyBox.PlaceholderColor3=Color3.fromRGB(75,85,115)
    keyBox.PlaceholderText=options.Placeholder or "enter authentication key..."
    keyBox.Text=""; keyBox.Font=Enum.Font.Gotham; keyBox.TextSize=12
    keyBox.ClearTextOnFocus=false; keyBox.BorderSizePixel=0; keyBox.Parent=holder
    corner(keyBox,7); stroke(keyBox,DEFAULT_THEME.Border,0,1)

    local function makeAuthBtn(text,xPos,w)
        local b=Instance.new("TextButton"); b.Size=UDim2.fromOffset(w or 160,30)
        b.Position=UDim2.fromOffset(xPos,102); b.BackgroundColor3=DEFAULT_THEME.Accent
        b.TextColor3=Color3.fromRGB(255,255,255); b.Text=text
        b.Font=Enum.Font.GothamBold; b.TextSize=12
        b.AutoButtonColor=false; b.BorderSizePixel=0; b.Parent=holder
        corner(b,7)
        hoverEffect(b,DEFAULT_THEME.Accent,DEFAULT_THEME.AccentGlow)
        return b
    end

    local midX = 380/2
    local authBtn   = makeAuthBtn(options.AuthText  or "Authenticate", 12, midX-18)
    local getKeyBtn = makeAuthBtn(options.GetKeyText or "Get Key",      midX-4, midX-18)

    local function setAuto(v, skip)
        autoExec=v==true
        TW:Create(tgl,FAST,{BackgroundColor3=autoExec and DEFAULT_THEME.Accent or Color3.fromRGB(30,34,50)}):Play()
        TW:Create(tglDot,FAST,{Position=autoExec and UDim2.fromOffset(15,2) or UDim2.fromOffset(2,2)}):Play()
        if not skip and type(options.OnAutoToggle)=="function" then pcall(options.OnAutoToggle,autoExec) end
    end

    tgl.MouseButton1Click:Connect(function() setAuto(not autoExec,false) end)
    authBtn.MouseButton1Click:Connect(function()
        if type(options.OnAuthenticate)=="function" then pcall(options.OnAuthenticate,keyBox.Text,autoExec) end
    end)
    getKeyBtn.MouseButton1Click:Connect(function()
        if type(options.OnGetKey)=="function" then pcall(options.OnGetKey) end
    end)
    setAuto(autoExec,true)

    TW:Create(holder,TweenInfo.new(0.5,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),
        {Position=UDim2.new(0.5,0,0,18)}):Play()

    local api={}
    function api:SetStatus(t,c) sub.Text=tostring(t or "") if typeof(c)=="Color3" then sub.TextColor3=c end end
    function api:SetTitle(t) title.Text=tostring(t or "") end
    function api:SetAutoExecute(v,s) setAuto(v,s==true) end
    function api:GetAutoExecute() return autoExec end
    function api:GetKey() return keyBox.Text end
    function api:SetKey(v) keyBox.Text=tostring(v or "") end
    function api:Show()
        holder.Visible=true
        TW:Create(holder,SLOW,{Position=UDim2.new(0.5,0,0,18)}):Play()
    end
    function api:Hide()
        local t=TW:Create(holder,MEDIUM,{Position=UDim2.new(0.5,0,0,-200)})
        t:Play(); t.Completed:Wait(); holder.Visible=false
    end
    function api:Destroy() if gui then gui:Destroy() end end

    api.Gui=gui; api.Frame=holder; api.Input=keyBox
    api.AuthenticateButton=authBtn; api.GetKeyButton=getKeyBtn
    return api
end

getgenv().EllaLibrary = EllaLibrary
return EllaLibrary
