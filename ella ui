function FloatingBar:Batch(list)
    if typeof(list) ~= "table" then
        return {}
    end

    local ids = {}
    for _, entry in ipairs(list) do
        if typeof(entry) == "table" then
            table.insert(ids, self:Notify(entry))
        end
    end
    return ids
end

function FloatingBar:Destroy()
    self:DismissAll(true)
    if self.Gui then
        self.Gui:Destroy()
    end
    self.Queue = {}
    self.QueuePaused = false
    self.IsShowing = false
    self.IsPumping = false
    self.ActiveItem = nil
    self.ActiveProgressTween = nil
end

local api = FloatingBar.new()
getgenv().EllaFloatingBar = api

return api
