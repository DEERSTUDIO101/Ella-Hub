local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local EllaLibrary = {}
EllaLibrary.__index = EllaLibrary

local function resolveGuiParent()
    if typeof(gethui) == "function" then
        local ok, gui = pcall(gethui)
        if ok and typeof(gui) == "Instance" then
            return gui
        end
    end
    return CoreGui
end

local function applyCorner(instance, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = instance
    return c
end

local function safeProtectGui(gui)
    if syn and syn.protect_gui then
        pcall(function()
            syn.protect_gui(gui)
        end)
    end
end

local function loadFloatingBar()
    local ok1, bar1 = pcall(function()
        if type(loadfile) == "function" then
            local chunk = loadfile("UI Library/src.lua")
            if type(chunk) == "function" then
                return chunk()
            end
        end
        return nil
    end)
    if ok1 and type(bar1) == "table" and type(bar1.Notify) == "function" then
        return bar1
    end

    local ok2, bar2 = pcall(function()
        if type(readfile) == "function" and type(loadstring) == "function" then
            local source = readfile("UI Library/src.lua")
            local chunk = loadstring(source)
            if type(chunk) == "function" then
                return chunk()
            end
        end
        return nil
    end)
    if ok2 and type(bar2) == "table" and type(bar2.Notify) == "function" then
        return bar2
    end

    return nil
end

local function createButton(parent, text)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 0, 32)
    b.BackgroundColor3 = Color3.fromRGB(26, 27, 35)
    b.TextColor3 = Color3.fromRGB(236, 239, 255)
    b.Font = Enum.Font.Gotham
    b.TextSize = 13
    b.Text = text or "Button"
    b.AutoButtonColor = false
    b.BorderSizePixel = 0
    b.Parent = parent
    applyCorner(b, 8)
    return b
end

local function createInfo(parent, title, desc)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 46)
    f.BackgroundColor3 = Color3.fromRGB(22, 23, 30)
    f.BorderSizePixel = 0
    f.Parent = parent
    applyCorner(f, 8)

    local t = Instance.new("TextLabel")
    t.BackgroundTransparency = 1
    t.Position = UDim2.fromOffset(10, 4)
    t.Size = UDim2.new(1, -16, 0, 18)
    t.Font = Enum.Font.GothamBold
    t.TextSize = 13
    t.TextXAlignment = Enum.TextXAlignment.Left
    t.TextColor3 = Color3.fromRGB(244, 246, 255)
    t.Text = title or "Title"
    t.Parent = f

    local d = Instance.new("TextLabel")
    d.BackgroundTransparency = 1
    d.Position = UDim2.fromOffset(10, 21)
    d.Size = UDim2.new(1, -16, 0, 18)
    d.Font = Enum.Font.Gotham
    d.TextSize = 12
    d.TextXAlignment = Enum.TextXAlignment.Left
    d.TextColor3 = Color3.fromRGB(168, 174, 200)
    d.Text = desc or ""
    d.Parent = f

    return f, t, d
end

function EllaLibrary.CreateLib(windowTitle, themeName, options)
    options = options or {}

    local self = setmetatable({}, EllaLibrary)
    self.ThemeName = themeName or "DarkTheme"
    self.Accent = options.AccentColor or Color3.fromRGB(0, 170, 255)
    self.Notifier = options.Notifier or loadFloatingBar()
    self.Tabs = {}
    self.ActiveTab = nil

    local gui = Instance.new("ScreenGui")
    gui.Name = "EllaUI"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    gui.Parent = resolveGuiParent()
    safeProtectGui(gui)

    local root = Instance.new("Frame")
    root.Size = UDim2.fromOffset(720, 460)
    root.Position = UDim2.new(0.5, -360, 0.5, -230)
    root.BackgroundColor3 = Color3.fromRGB(16, 17, 22)
    root.BorderSizePixel = 0
    root.Parent = gui
    applyCorner(root, 12)

    local shadow = Instance.new("ImageLabel")
    shadow.BackgroundTransparency = 1
    shadow.Size = UDim2.new(1, 56, 1, 56)
    shadow.Position = UDim2.fromOffset(-28, -28)
    shadow.Image = "rbxassetid://6014261993"
    shadow.ImageTransparency = 0.62
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(49, 49, 450, 450)
    shadow.ZIndex = 0
    shadow.Parent = root

    local top = Instance.new("Frame")
    top.Size = UDim2.new(1, 0, 0, 46)
    top.BackgroundColor3 = Color3.fromRGB(20, 21, 28)
    top.BorderSizePixel = 0
    top.Parent = root
    applyCorner(top, 12)

    local title = Instance.new("TextLabel")
    title.BackgroundTransparency = 1
    title.Position = UDim2.fromOffset(14, 0)
    title.Size = UDim2.new(1, -28, 1, 0)
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.TextSize = 14
    title.TextColor3 = Color3.fromRGB(242, 245, 255)
    title.Text = windowTitle or "Ella UI"
    title.Parent = top

    local tabList = Instance.new("ScrollingFrame")
    tabList.Name = "TabList"
    tabList.Position = UDim2.fromOffset(12, 56)
    tabList.Size = UDim2.fromOffset(190, 392)
    tabList.BackgroundColor3 = Color3.fromRGB(20, 21, 28)
    tabList.BorderSizePixel = 0
    tabList.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabList.ScrollBarImageColor3 = Color3.fromRGB(80, 85, 108)
    tabList.ScrollBarThickness = 3
    tabList.Parent = root
    applyCorner(tabList, 10)

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.Padding = UDim.new(0, 6)
    tabLayout.Parent = tabList

    local pages = Instance.new("Frame")
    pages.Position = UDim2.fromOffset(212, 56)
    pages.Size = UDim2.fromOffset(496, 392)
    pages.BackgroundColor3 = Color3.fromRGB(20, 21, 28)
    pages.BorderSizePixel = 0
    pages.Parent = root
    applyCorner(pages, 10)

    local dragging = false
    local dragStart
    local startPos

    top.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = root.Position
        end
    end)

    top.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not dragging then
            return
        end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            root.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    local function updateTabCanvas()
        tabList.CanvasSize = UDim2.new(0, 0, 0, tabLayout.AbsoluteContentSize.Y + 8)
    end
    tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateTabCanvas)

    function self:Notify(dataOrTitle, content, duration)
        if not self.Notifier then
            return
        end
        if type(dataOrTitle) == "table" then
            self.Notifier:Notify(dataOrTitle)
        else
            self.Notifier:Notify({
                Title = tostring(dataOrTitle or "Notification"),
                Content = tostring(content or ""),
                Duration = duration
            })
        end
    end

    function self:Destroy()
        if gui then
            gui:Destroy()
        end
    end

    function self:NewTab(tabName)
        local library = self
        local tab = {}
        local pageVisible = false

        local tabButton = createButton(tabList, tostring(tabName or "Tab"))
        tabButton.TextXAlignment = Enum.TextXAlignment.Left
        tabButton.Text = "   " .. tostring(tabName or "Tab")
        tabButton.BackgroundColor3 = Color3.fromRGB(27, 29, 38)

        local indicator = Instance.new("Frame")
        indicator.Size = UDim2.fromOffset(4, 20)
        indicator.Position = UDim2.new(0, 8, 0.5, -10)
        indicator.BackgroundColor3 = library.Accent
        indicator.BorderSizePixel = 0
        indicator.Visible = false
        indicator.Parent = tabButton
        applyCorner(indicator, 12)

        local page = Instance.new("ScrollingFrame")
        page.Name = tostring(tabName or "Tab") .. "_Page"
        page.Size = UDim2.new(1, -12, 1, -12)
        page.Position = UDim2.fromOffset(6, 6)
        page.BackgroundTransparency = 1
        page.BorderSizePixel = 0
        page.ScrollBarThickness = 4
        page.ScrollBarImageColor3 = Color3.fromRGB(80, 85, 108)
        page.CanvasSize = UDim2.new(0, 0, 0, 0)
        page.Visible = false
        page.Parent = pages

        local pageLayout = Instance.new("UIListLayout")
        pageLayout.Padding = UDim.new(0, 8)
        pageLayout.Parent = page

        pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            page.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 10)
        end)

        function tab:SetActive(active)
            pageVisible = active == true
            page.Visible = pageVisible
            indicator.Visible = pageVisible
            tabButton.BackgroundColor3 = pageVisible and Color3.fromRGB(34, 36, 48) or Color3.fromRGB(27, 29, 38)
        end

        function tab:NewSection(sectionTitle)
            local section = {}

            local holder = Instance.new("Frame")
            holder.Size = UDim2.new(1, 0, 0, 44)
            holder.BackgroundColor3 = Color3.fromRGB(24, 26, 34)
            holder.BorderSizePixel = 0
            holder.Parent = page
            applyCorner(holder, 10)

            local secTitle = Instance.new("TextLabel")
            secTitle.BackgroundTransparency = 1
            secTitle.Position = UDim2.fromOffset(12, 6)
            secTitle.Size = UDim2.new(1, -24, 0, 20)
            secTitle.Font = Enum.Font.GothamBold
            secTitle.TextXAlignment = Enum.TextXAlignment.Left
            secTitle.TextSize = 14
            secTitle.TextColor3 = Color3.fromRGB(245, 247, 255)
            secTitle.Text = tostring(sectionTitle or "Section")
            secTitle.Parent = holder

            local controls = Instance.new("Frame")
            controls.BackgroundTransparency = 1
            controls.Position = UDim2.fromOffset(10, 30)
            controls.Size = UDim2.new(1, -20, 0, 10)
            controls.Parent = holder

            local controlsLayout = Instance.new("UIListLayout")
            controlsLayout.Padding = UDim.new(0, 6)
            controlsLayout.Parent = controls

            local function resizeSection()
                holder.Size = UDim2.new(1, 0, 0, controlsLayout.AbsoluteContentSize.Y + 38)
            end
            controlsLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(resizeSection)
            resizeSection()

            function section:NewLabel(text)
                local f = Instance.new("Frame")
                f.Size = UDim2.new(1, 0, 0, 30)
                f.BackgroundColor3 = Color3.fromRGB(21, 22, 29)
                f.BorderSizePixel = 0
                f.Parent = controls
                applyCorner(f, 8)

                local l = Instance.new("TextLabel")
                l.BackgroundTransparency = 1
                l.Position = UDim2.fromOffset(10, 0)
                l.Size = UDim2.new(1, -16, 1, 0)
                l.Font = Enum.Font.Gotham
                l.TextSize = 13
                l.TextColor3 = Color3.fromRGB(223, 227, 245)
                l.TextXAlignment = Enum.TextXAlignment.Left
                l.Text = tostring(text or "")
                l.Parent = f

                return {
                    UpdateLabel = function(_, newText)
                        l.Text = tostring(newText or "")
                    end
                }
            end

            function section:NewButton(name, desc, callback)
                local f = createInfo(controls, name, desc)
                local click = Instance.new("TextButton")
                click.BackgroundTransparency = 1
                click.Size = UDim2.fromScale(1, 1)
                click.Text = ""
                click.Parent = f

                click.MouseButton1Click:Connect(function()
                    if type(callback) == "function" then
                        callback()
                    end
                end)
                return click
            end

            function section:NewToggle(name, desc, callback)
                local state = false
                local f = createInfo(controls, name, desc)

                local toggle = Instance.new("TextButton")
                toggle.Size = UDim2.fromOffset(52, 24)
                toggle.Position = UDim2.new(1, -62, 0.5, -12)
                toggle.BackgroundColor3 = Color3.fromRGB(35, 37, 48)
                toggle.Text = ""
                toggle.AutoButtonColor = false
                toggle.BorderSizePixel = 0
                toggle.Parent = f
                applyCorner(toggle, 999)

                local dot = Instance.new("Frame")
                dot.Size = UDim2.fromOffset(18, 18)
                dot.Position = UDim2.fromOffset(3, 3)
                dot.BackgroundColor3 = Color3.fromRGB(220, 224, 244)
                dot.BorderSizePixel = 0
                dot.Parent = toggle
                applyCorner(dot, 999)

                local function setState(newState)
                    state = newState == true
                    TweenService:Create(toggle, TweenInfo.new(0.2), {
                        BackgroundColor3 = state and library.Accent or Color3.fromRGB(35, 37, 48)
                    }):Play()
                    TweenService:Create(dot, TweenInfo.new(0.2), {
                        Position = state and UDim2.fromOffset(31, 3) or UDim2.fromOffset(3, 3)
                    }):Play()
                    if type(callback) == "function" then
                        callback(state)
                    end
                end

                toggle.MouseButton1Click:Connect(function()
                    setState(not state)
                end)

                return {
                    Set = function(_, value)
                        setState(value)
                    end,
                    Get = function()
                        return state
                    end
                }
            end

            function section:NewSlider(name, desc, max, min, callback)
                max = tonumber(max) or 100
                min = tonumber(min) or 0
                local value = min
                local draggingSlider = false

                local f, titleLabel, descLabel = createInfo(controls, name, desc)
                descLabel.Text = tostring(desc or "") .. " (" .. tostring(value) .. ")"

                local bar = Instance.new("Frame")
                bar.Size = UDim2.new(1, -16, 0, 6)
                bar.Position = UDim2.new(0, 8, 1, -10)
                bar.BackgroundColor3 = Color3.fromRGB(36, 39, 52)
                bar.BorderSizePixel = 0
                bar.Parent = f
                applyCorner(bar, 999)

                local fill = Instance.new("Frame")
                fill.Size = UDim2.new(0, 0, 1, 0)
                fill.BackgroundColor3 = library.Accent
                fill.BorderSizePixel = 0
                fill.Parent = bar
                applyCorner(fill, 999)

                local function updateFromX(xPos)
                    local alpha = math.clamp((xPos - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    value = math.floor(min + ((max - min) * alpha) + 0.5)
                    fill.Size = UDim2.new(alpha, 0, 1, 0)
                    descLabel.Text = tostring(desc or "") .. " (" .. tostring(value) .. ")"
                    if type(callback) == "function" then
                        callback(value)
                    end
                end

                f.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = true
                        updateFromX(input.Position.X)
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateFromX(input.Position.X)
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = false
                    end
                end)

                return {
                    Set = function(_, newValue)
                        newValue = math.clamp(tonumber(newValue) or min, min, max)
                        value = math.floor(newValue + 0.5)
                        local alpha = (value - min) / (max - min)
                        fill.Size = UDim2.new(alpha, 0, 1, 0)
                        descLabel.Text = tostring(desc or "") .. " (" .. tostring(value) .. ")"
                        if type(callback) == "function" then
                            callback(value)
                        end
                    end,
                    Get = function()
                        return value
                    end,
                    Label = titleLabel
                }
            end

            return section
        end

        tabButton.MouseButton1Click:Connect(function()
            for _, t in ipairs(self.Tabs) do
                t:SetActive(false)
            end
            tab:SetActive(true)
            self.ActiveTab = tab
        end)

        table.insert(self.Tabs, tab)
        if #self.Tabs == 1 then
            tab:SetActive(true)
            self.ActiveTab = tab
        end

        return tab
    end

    return self
end

getgenv().EllaLibrary = EllaLibrary
return EllaLibrary
