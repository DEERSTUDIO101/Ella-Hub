function FloatingBar:_getTopMargin()
    local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize
    local isMobile = UserInputService.TouchEnabled
    if viewport then
        isMobile = isMobile or (viewport.X < 1024 and viewport.Y < 768)
    end

    if isMobile then
        return self.MobileMarginTop
    end
    return self.MarginTop
end

function FloatingBar:_tweenOrSet(instance, info, goal)
    if self.UIAnimationsEnabled then
        local tween = TweenService:Create(instance, info, goal)
        tween:Play()
        return tween
    end

    for property, value in pairs(goal) do
        instance[property] = value
    end

    return nil
end

function FloatingBar:_debugPrint(...)
    if not self.Debug then
        return
    end
    local pieces = table.create(select("#", ...))
    for i = 1, select("#", ...) do
        pieces[i] = tostring(select(i, ...))
    end
    print("[EllaFloatingBar]", table.concat(pieces, " "))
end

function FloatingBar:_applyLayout()
    if not self.Holder then
        return
    end
    self.Holder.Size = UDim2.fromOffset(self.Width, self.Height)
    self.Accent.Size = UDim2.fromOffset(4, math.max(self.Height - 18, 10))
    self.ProgressTrack.Position = UDim2.new(0.5, 0, 1, -6)
    self.ProgressTrack.Size = UDim2.new(1, -24, 0, 3)
end

function FloatingBar:_play(item)
    self.IsShowing = true
    self.ActiveItem = item
    self.DismissRequested = false
    self.DismissInstant = false
    self:_debugPrint("show", item.Id, item.Title)

    self.Title.Text = item.Title
    self.Message.Text = item.Message
    self.Icon.Image = item.Icon
    self.Stroke.Color = item.AccentColor
    self.Accent.BackgroundColor3 = item.AccentColor
    self.ProgressFill.BackgroundColor3 = item.AccentColor
    self.ProgressFill.Size = UDim2.new(1, 0, 1, 0)

    self.Holder.Position = UDim2.new(0.5, 0, 0, -self.Height - 20)
    self.Holder.BackgroundTransparency = 1

    local tweenIn = self:_tweenOrSet(
        self.Holder,
        TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
        {
            Position = UDim2.new(0.5, 0, 0, self:_getTopMargin()),
            BackgroundTransparency = self.Theme.BackgroundTransparency
        }
    )
    if tweenIn then
        tweenIn.Completed:Wait()
    end

    local progressTween = self:_tweenOrSet(
        self.ProgressFill,
        TweenInfo.new(item.Duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
        {
            Size = UDim2.new(0, 0, 1, 0)
        }
    )
    self.ActiveProgressTween = progressTween
    if not progressTween then
        self.ProgressFill.Size = UDim2.new(0, 0, 1, 0)
    end

    safeCall(self.OnShow, item)

    local startTime = os.clock()
    while os.clock() - startTime < item.Duration do
        if self.DismissRequested then
            break
        end
        task.wait(0.03)
    end

    if self.ActiveProgressTween then
        pcall(function()
            self.ActiveProgressTween:Cancel()
        end)
        self.ActiveProgressTween = nil
    end

    if self.DismissRequested and self.DismissInstant then
        self.Holder.Position = UDim2.new(0.5, 0, 0, -self.Height - 20)
        self.Holder.BackgroundTransparency = 1
        self.IsShowing = false
        self.ActiveItem = nil
        safeCall(self.OnHide, item)
        self:_debugPrint("hide-instant", item.Id, item.Title)
        return
    end

    local tweenOut = self:_tweenOrSet(
        self.Holder,
        TweenInfo.new(0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
        {
            Position = UDim2.new(0.5, 0, 0, -self.Height - 20),
            BackgroundTransparency = 1
        }
    )
    if tweenOut then
        tweenOut.Completed:Wait()
    end

    self.IsShowing = false
    self.ActiveItem = nil
    safeCall(self.OnHide, item)
    self:_debugPrint("hide", item.Id, item.Title)
end

function FloatingBar:_pump()
    if self.IsShowing or self.IsPumping then
        return
    end

    self.IsPumping = true
    task.spawn(function()
        while #self.Queue > 0 do
            while self.QueuePaused do
                if #self.Queue == 0 then
                    break
                end
                task.wait(0.05)
            end
            if #self.Queue == 0 then
                break
            end
            local item = table.remove(self.Queue, 1)
            self:_play(item)
            task.wait(0.06)
        end
        self.IsPumping = false
        safeCall(self.OnQueueEmpty)
        self:_debugPrint("queue-empty")
    end)
end

function FloatingBar:SetAnimationsEnabled(enabled)
    self.UIAnimationsEnabled = enabled ~= false
end

function FloatingBar:SetDebug(enabled)
    self.Debug = enabled == true
end

function FloatingBar:SetCallbacks(callbacks)
    if typeof(callbacks) ~= "table" then
        return
    end
    if callbacks.OnShow ~= nil then
        self.OnShow = callbacks.OnShow
    end
    if callbacks.OnHide ~= nil then
        self.OnHide = callbacks.OnHide
    end
    if callbacks.OnQueueEmpty ~= nil then
        self.OnQueueEmpty = callbacks.OnQueueEmpty
    end
end

function FloatingBar:SetMaxQueue(maxQueue)
    maxQueue = tonumber(maxQueue) or self.MaxQueue
    if maxQueue < 1 then
        maxQueue = 1
    end
    self.MaxQueue = math.floor(maxQueue)
end

function FloatingBar:SetDefaultDuration(duration)
    duration = tonumber(duration) or self.DefaultDuration
    if duration <= 0 then
        duration = 0.1
    end
    self.DefaultDuration = duration
end

function FloatingBar:SetAccentColor(color)
    if typeof(color) ~= "Color3" then
        return
    end
    self.AccentColor = color
    if not self.ActiveItem then
        self.Stroke.Color = color
        self.Accent.BackgroundColor3 = color
        self.ProgressFill.BackgroundColor3 = color
    end
end

function FloatingBar:SetMargins(desktopTop, mobileTop)
    if tonumber(desktopTop) then
        self.MarginTop = tonumber(desktopTop)
    end
    if tonumber(mobileTop) then
        self.MobileMarginTop = tonumber(mobileTop)
    end
end

function FloatingBar:SetSize(width, height)
    width = tonumber(width) or self.Width
    height = tonumber(height) or self.Height
    if width < 220 then
        width = 220
    end
    if height < 52 then
        height = 52
    end

    self.Width = math.floor(width)
    self.Height = math.floor(height)
    self:_applyLayout()
end

function FloatingBar:SetParent(parent)
    if typeof(parent) ~= "Instance" then
        return false
    end
    self.ParentOverride = parent
    if self.Gui then
        self.Gui.Parent = parent
    end
    return true
end

function FloatingBar:SetFonts(titleFont, bodyFont)
    if titleFont then
        self.Title.Font = titleFont
    end
    if bodyFont then
        self.Message.Font = bodyFont
    end
end

function FloatingBar:SetTextSizes(titleSize, bodySize)
    if tonumber(titleSize) then
        self.Title.TextSize = tonumber(titleSize)
    end
    if tonumber(bodySize) then
        self.Message.TextSize = tonumber(bodySize)
    end
end

function FloatingBar:SetIconColor(color)
    if typeof(color) ~= "Color3" then
        return
    end
    self.Icon.ImageColor3 = color
end

function FloatingBar:SetTheme(theme)
    if typeof(theme) ~= "table" then
        return
    end

    if theme.Background then
        self.Theme.Background = theme.Background
        self.Holder.BackgroundColor3 = theme.Background
    end
    if theme.TitleText then
        self.Theme.TitleText = theme.TitleText
        self.Title.TextColor3 = theme.TitleText
    end
    if theme.BodyText then
        self.Theme.BodyText = theme.BodyText
        self.Message.TextColor3 = theme.BodyText
    end
    if theme.BackgroundTransparency then
        self.Theme.BackgroundTransparency = theme.BackgroundTransparency
        self.Holder.BackgroundTransparency = theme.BackgroundTransparency
    end
    if theme.StrokeTransparency then
        self.Theme.StrokeTransparency = theme.StrokeTransparency
        self.Stroke.Transparency = theme.StrokeTransparency
    end
    if theme.ProgressTrackTransparency then
        self.Theme.ProgressTrackTransparency = theme.ProgressTrackTransparency
        self.ProgressTrack.BackgroundTransparency = theme.ProgressTrackTransparency
    end
end

function FloatingBar:PauseQueue()
    self.QueuePaused = true
end

function FloatingBar:ResumeQueue()
    self.QueuePaused = false
    self:_pump()
end

function FloatingBar:ClearQueue()
    local count = #self.Queue
    self.Queue = {}
    return count
end

function FloatingBar:GetQueueSize()
    return #self.Queue
end

function FloatingBar:GetState()
    return {
        IsShowing = self.IsShowing,
        IsPumping = self.IsPumping,
        QueuePaused = self.QueuePaused,
        QueueSize = #self.Queue,
        ActiveId = self.ActiveItem and self.ActiveItem.Id or nil
    }
end

function FloatingBar:IsBusy()
    return self.IsShowing or self.IsPumping
end

function FloatingBar:DismissCurrent(instant)
    if not self.ActiveItem then
        return false
    end
    self.DismissRequested = true
    self.DismissInstant = instant == true
    return true
end

function FloatingBar:DismissById(id, instant)
    if self.ActiveItem and self.ActiveItem.Id == id then
        return self:DismissCurrent(instant)
    end

    for i, item in ipairs(self.Queue) do
        if item.Id == id then
            table.remove(self.Queue, i)
            return true
        end
    end

    return false
end

function FloatingBar:DismissAll(instant)
    self:ClearQueue()
    self:DismissCurrent(instant == nil or instant)
end

function FloatingBar:RegisterVariant(name, data)
    if not name or typeof(data) ~= "table" then
        return false
    end
    local variantName = tostring(name)
    VARIANTS[variantName] = {
        AccentColor = typeof(data.AccentColor) == "Color3" and data.AccentColor or self.AccentColor,
        Icon = normalizeImageSource(data.Icon or DEFAULT_ICON)
    }
    return true
end

function FloatingBar:RemoveVariant(name)
    local variantName = tostring(name or "")
    if variantName == "" or variantName == "Default" then
        return false
    end
    VARIANTS[variantName] = nil
    return true
end

function FloatingBar:GetVariant(name)
    local variantName = tostring(name or "Default")
    local variant = VARIANTS[variantName]
    if not variant then
        return nil
    end
    return {
        AccentColor = variant.AccentColor,
        Icon = variant.Icon
    }
end

function FloatingBar:GetVariants()
    local result = {}
    for name, variant in pairs(VARIANTS) do
        result[name] = {
            AccentColor = variant.AccentColor,
            Icon = variant.Icon
        }
    end
    return result
end

local function resolveVariantName(data)
    local variant = data.Variant or data.Varient or "Default"
    variant = tostring(variant)
    if VARIANTS[variant] then
        return variant
    end
    return "Default"
end

function FloatingBar:_enqueue(data)
    self.NextId += 1

    local variantName = resolveVariantName(data)
    local variant = VARIANTS[variantName]
    local resolvedIcon = normalizeImageSource(data.Icon or variant.Icon)
    if resolvedIcon == "" then
        resolvedIcon = DEFAULT_ICON
    end

    local resolvedAccent = data.AccentColor or variant.AccentColor or self.AccentColor
    if typeof(resolvedAccent) ~= "Color3" then
        resolvedAccent = self.AccentColor
    end

    if #self.Queue >= self.MaxQueue then
        table.remove(self.Queue, 1)
    end

    local item = {
        Id = self.NextId,
        Title = tostring(data.Title or "Notification"),
        Message = tostring(data.Content or data.Message or ""),
        Duration = tonumber(data.Duration) or self.DefaultDuration,
        Icon = resolvedIcon,
        AccentColor = resolvedAccent,
        Variant = variantName
    }

    if item.Duration <= 0 then
        item.Duration = 0.1
    end

    table.insert(self.Queue, item)
    self:_pump()
    return item.Id
end

function FloatingBar:Notify(title, message, duration, icon, accentColor)
    local data
    if typeof(title) == "table" then
        data = title
        if data.AccentColor == nil and accentColor ~= nil then
            data.AccentColor = accentColor
        end
    else
        data = {
            Title = title,
            Content = message,
            Duration = duration,
            Icon = icon,
            AccentColor = accentColor
        }
    end

    return self:_enqueue(data)
end

function FloatingBar:Push(...)
    return self:Notify(...)
end

function FloatingBar:Info(title, message, duration, icon, accentColor)
    return self:Notify({
        Title = title,
        Content = message,
        Duration = duration,
        Icon = icon,
        AccentColor = accentColor,
        Variant = "Info"
    })
end

