        tabButton.BackgroundColor3 = self.Theme.Surface
        tabButton.Text = "   " .. tostring(text)
        tabButton.Font = Enum.Font.Gotham
        tabButton.TextSize = 13
        tabButton.TextXAlignment = Enum.TextXAlignment.Left
        tabButton.TextColor3 = self.Theme.Text
        tabButton.AutoButtonColor = false
        tabButton.BorderSizePixel = 0
        tabButton.Parent = tabList
        applyCorner(tabButton, 8)

        local indicator = Instance.new("Frame")
        indicator.Size = UDim2.fromOffset(4, 22)
        indicator.Position = UDim2.new(0, 8, 0.5, -11)
        indicator.BackgroundColor3 = self.Theme.Accent
        indicator.BorderSizePixel = 0
        indicator.Visible = false
        indicator.Parent = tabButton
        applyCorner(indicator, 8)

        trackThemeObject(tabButton, "Surface")
        trackThemeObject(indicator, "Accent")
        return tabButton, indicator
    end

    local function registerFlag(flag, valueType, callback, setter, defaultValue)
        if not flag then
            return
        end

        self.Flags[flag] = {
            Type = valueType,
            Value = defaultValue,
            Callback = callback
        }
        self.FlagSetters[flag] = function(v, skipCallback)
            setter(v, skipCallback)
            self.Flags[flag].Value = v
            if not skipCallback and type(callback) == "function" then
                callback(v)
            end
        end
    end

