        page.Parent                = content

        local pageLayout = Instance.new("UIListLayout")
        pageLayout.Padding         = UDim.new(0,8)
        pageLayout.Parent          = page
        padding(page, nil, 0, 4, 0, 8)

        table.insert(lib.Connections, pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            page.CanvasSize = UDim2.new(0,0,0,pageLayout.AbsoluteContentSize.Y+16)
        end))

        function tab:SetActive(active)
            page.Visible = active==true
            setTabActive(active==true)
        end

        table.insert(lib.Connections, tabBtn.MouseButton1Click:Connect(function()
            for _,t in ipairs(lib.Tabs) do t:SetActive(false) end
            tab:SetActive(true)
            lib.ActiveTab = tab
        end))

        table.insert(lib.Tabs, tab)
        if #lib.Tabs==1 then tab:SetActive(true) lib.ActiveTab=tab end

