            function section:NewDropdown(name, desc, optionsList, callback)
                local data = parseArgs(name, desc, callback)
                data.Options = data.Options or optionsList or {}
                data.Default = data.Default or nil
                local selected = data.Multi and {} or nil

                local f, _, descLabel = createInfoCard(controls, library.Theme, data.Title, data.Description, 70)
                local dropBtn = Instance.new("TextButton")
                dropBtn.Size = UDim2.new(1, -16, 0, 24)
                dropBtn.Position = UDim2.new(0, 8, 1, -30)
                dropBtn.BackgroundColor3 = library.Theme.Input
                dropBtn.TextColor3 = library.Theme.Text
                dropBtn.TextXAlignment = Enum.TextXAlignment.Left
                dropBtn.Text = "  " .. tostring(data.Placeholder or "Select option...")
                dropBtn.Font = Enum.Font.Gotham
                dropBtn.TextSize = 12
                dropBtn.BorderSizePixel = 0
                dropBtn.AutoButtonColor = false
                dropBtn.Parent = f
                applyCorner(dropBtn, 6)
                makeStroke(dropBtn, Color3.fromRGB(58, 62, 79), 0.45)

                local arrow = Instance.new("TextLabel")
                arrow.BackgroundTransparency = 1
                arrow.Size = UDim2.fromOffset(20, 20)
                arrow.Position = UDim2.new(1, -22, 0, 2)
                arrow.Font = Enum.Font.GothamBold
                arrow.TextSize = 12
                arrow.TextColor3 = library.Theme.SubText
                arrow.Text = "v"
                arrow.Parent = dropBtn

                local list = Instance.new("ScrollingFrame")
                list.Size = UDim2.new(1, -16, 0, 0)
                list.Position = UDim2.new(0, 8, 1, -2)
                list.BackgroundColor3 = library.Theme.Input
                list.BorderSizePixel = 0
                list.ScrollBarThickness = 3
                list.ScrollBarImageColor3 = Color3.fromRGB(80, 85, 108)
                list.Visible = false
                list.ZIndex = 20
                list.Parent = f
                applyCorner(list, 6)
                makeStroke(list, Color3.fromRGB(58, 62, 79), 0.45)

                local listLayout = Instance.new("UIListLayout")
                listLayout.Padding = UDim.new(0, 4)
                listLayout.Parent = list

                local function updateListCanvas()
                    list.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 6)
                end
                table.insert(library.Connections, listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateListCanvas))

                local function setDisplay()
                    if data.Multi then
                        local keys = {}
                        for option, isOn in pairs(selected) do
                            if isOn then
                                table.insert(keys, option)
                            end
                        end
                        table.sort(keys)
                        if #keys == 0 then
                            dropBtn.Text = "  " .. tostring(data.Placeholder or "Select option...")
                        else
                            dropBtn.Text = "  " .. table.concat(keys, ", ")
                        end
                        descLabel.Text = tostring(data.Description or "") .. " (" .. tostring(#keys) .. " selected)"
                    else
                        dropBtn.Text = "  " .. tostring(selected or data.Placeholder or "Select option...")
                    end
                end

                local function callbackValue()
                    if type(data.Callback) == "function" then
                        if data.Multi then
                            local out = {}
                            for option, isOn in pairs(selected) do
                                if isOn then
                                    table.insert(out, option)
                                end
                            end
                            table.sort(out)
                            data.Callback(out)
                        else
                            data.Callback(selected)
                        end
                    end
                end

                local function setOpen(open)
                    if open and library.LastOpenedDropdown and library.LastOpenedDropdown ~= list then
                        library.LastOpenedDropdown.Visible = false
                        library.LastOpenedDropdown.Size = UDim2.new(1, -16, 0, 0)
                    end

                    list.Visible = open
                    arrow.Text = open and "^" or "v"
                    if open then
                        local targetHeight = math.clamp(listLayout.AbsoluteContentSize.Y + 8, 0, 140)
                        list.Size = UDim2.new(1, -16, 0, targetHeight)
                        library.LastOpenedDropdown = list
                    else
                        list.Size = UDim2.new(1, -16, 0, 0)
                    end
                end

                local function setSelected(value, skipCallback)
                    if data.Multi then
                        if type(value) == "table" then
                            selected = {}
                            for _, entry in ipairs(value) do
                                selected[tostring(entry)] = true
                            end
                        elseif value ~= nil then
                            local key = tostring(value)
                            selected[key] = not selected[key]
                        end
                    else
                        selected = value and tostring(value) or nil
                    end

                    setDisplay()
                    if not skipCallback then
                        callbackValue()
                    end

                    if data.Flag then
                        if data.Multi then
                            local out = {}
                            for k, v in pairs(selected) do
                                if v then
                                    table.insert(out, k)
                                end
                            end
                            library.Flags[data.Flag].Value = out
                        else
                            library.Flags[data.Flag].Value = selected
                        end
                    end
                end

                for _, option in ipairs(data.Options) do
                    local o = Instance.new("TextButton")
                    o.Size = UDim2.new(1, -8, 0, 24)
                    o.Position = UDim2.fromOffset(4, 0)
                    o.BackgroundColor3 = library.Theme.SurfaceSoft
                    o.BorderSizePixel = 0
                    o.TextXAlignment = Enum.TextXAlignment.Left
                    o.Font = Enum.Font.Gotham
                    o.TextSize = 12
                    o.TextColor3 = library.Theme.Text
                    o.Text = "  " .. tostring(option)
                    o.Parent = list
                    applyCorner(o, 6)

                    table.insert(library.Connections, o.MouseButton1Click:Connect(function()
                        setSelected(option, false)
                        if not data.Multi then
                            setOpen(false)
                        end
                    end))
                end
                updateListCanvas()

                table.insert(library.Connections, dropBtn.MouseButton1Click:Connect(function()
                    setOpen(not list.Visible)
                end))

                if data.Flag then
                    local defaultStored = data.Multi and {} or data.Default
                    registerFlag(data.Flag, "Dropdown", data.Callback, setSelected, defaultStored)
                end

                if data.Default then
                    setSelected(data.Default, true)
                else
                    setDisplay()
                end

                return {
                    Set = function(_, value, skip)
                        setSelected(value, skip == true)
                    end,
                    Get = function()
                        if data.Multi then
                            local out = {}
                            for k, v in pairs(selected) do
                                if v then
                                    table.insert(out, k)
                                end
                            end
                            table.sort(out)
                            return out
                        end
                        return selected
                    end,
                    Refresh = function(_, newOptions)
                        if type(newOptions) == "table" then
                            data.Options = newOptions
                        end
                    end
                }
            end

            function section:NewKeybind(name, desc, defaultKey, callback)
                local data = parseArgs(name, desc, callback)
                data.Key = data.Key or defaultKey or Enum.KeyCode.Unknown
                local current = data.Key

                local f = createInfoCard(controls, library.Theme, data.Title, data.Description, 46)
                local bind = Instance.new("TextButton")
                bind.Size = UDim2.fromOffset(90, 24)
                bind.Position = UDim2.new(1, -100, 0.5, -12)
                bind.BackgroundColor3 = library.Theme.Input
                bind.TextColor3 = library.Theme.Text
                bind.Font = Enum.Font.Gotham
                bind.TextSize = 12
                bind.Text = current == Enum.KeyCode.Unknown and "None" or current.Name
                bind.BorderSizePixel = 0
                bind.Parent = f
                applyCorner(bind, 6)
                makeStroke(bind, Color3.fromRGB(58, 62, 79), 0.45)

                local listening = false

                local function setKey(keyCode, skipCallback)
                    if typeof(keyCode) ~= "EnumItem" or keyCode.EnumType ~= Enum.KeyCode then
                        return
                    end
                    current = keyCode
                    bind.Text = current == Enum.KeyCode.Unknown and "None" or current.Name
                    if data.Flag and library.Flags[data.Flag] then
                        library.Flags[data.Flag].Value = current
                    end
                    if not skipCallback and type(data.Callback) == "function" then
                        data.Callback(current)
                    end
                end

                table.insert(library.Connections, bind.MouseButton1Click:Connect(function()
                    listening = true
                    bind.Text = "..."
                end))

                table.insert(library.Connections, UserInputService.InputBegan:Connect(function(input, processed)
                    if processed or not listening then
                        return
                    end
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        listening = false
                        setKey(input.KeyCode, true)
                    end
                end))

                if data.Flag then
                    registerFlag(data.Flag, "Keybind", data.Callback, setKey, current)
                end

                library.Flags[data.Flag or ("__keybind_" .. tostring(current.Name))] = {
                    Type = "Keybind",
                    Key = current,
                    Callback = data.Callback,
                    Value = current
                }

                return {
                    Set = function(_, keyCode, skip)
                        setKey(keyCode, skip == true)
                    end,
                    Get = function()
                        return current
                    end
                }
            end

            function section:NewColorPicker(name, desc, callback)
                local data = parseArgs(name, desc, callback)
                local value = data.Color or data.Default or Color3.fromRGB(255, 255, 255)
                local f = createInfoCard(controls, library.Theme, data.Title, data.Description, 70)

                local preview = Instance.new("TextButton")
                preview.Size = UDim2.fromOffset(32, 20)
                preview.Position = UDim2.new(1, -42, 6/70, 0)
                preview.BackgroundColor3 = value
                preview.Text = ""
                preview.BorderSizePixel = 0
                preview.Parent = f
                applyCorner(preview, 5)
                makeStroke(preview, Color3.fromRGB(255, 255, 255), 0.5)

                local rBox = Instance.new("TextBox")
                local gBox = Instance.new("TextBox")
                local bBox = Instance.new("TextBox")
                local boxes = { rBox, gBox, bBox }

                for i, box in ipairs(boxes) do
                    box.Size = UDim2.fromOffset(48, 22)
                    box.Position = UDim2.new(0, 8 + ((i - 1) * 54), 1, -28)
                    box.BackgroundColor3 = library.Theme.Input
                    box.TextColor3 = library.Theme.Text
                    box.PlaceholderColor3 = library.Theme.SubText
                    box.Font = Enum.Font.Gotham
                    box.TextSize = 12
                    box.BorderSizePixel = 0
                    box.ClearTextOnFocus = false
                    box.Parent = f
                    applyCorner(box, 6)
                end
                rBox.PlaceholderText = "R"
                gBox.PlaceholderText = "G"
                bBox.PlaceholderText = "B"

                local function syncBoxes()
                    rBox.Text = tostring(math.floor(value.R * 255 + 0.5))
                    gBox.Text = tostring(math.floor(value.G * 255 + 0.5))
                    bBox.Text = tostring(math.floor(value.B * 255 + 0.5))
                    preview.BackgroundColor3 = value
                end

                local function setColor(newColor, skipCallback)
                    if typeof(newColor) ~= "Color3" then
                        return
                    end
                    value = newColor
                    syncBoxes()
                    if data.Flag and library.Flags[data.Flag] then
                        library.Flags[data.Flag].Value = value
                    end
                    if not skipCallback and type(data.Callback) == "function" then
                        data.Callback(value)
                    end
                end

                local function applyFromBoxes()
                    local r = math.clamp(tonumber(rBox.Text) or 255, 0, 255)
                    local g = math.clamp(tonumber(gBox.Text) or 255, 0, 255)
                    local b = math.clamp(tonumber(bBox.Text) or 255, 0, 255)
                    setColor(Color3.fromRGB(r, g, b), false)
                end

                for _, box in ipairs(boxes) do
                    table.insert(library.Connections, box.FocusLost:Connect(function()
                        applyFromBoxes()
                    end))
                end

                if data.Flag then
                    registerFlag(data.Flag, "ColorPicker", data.Callback, setColor, value)
                end

                syncBoxes()
                return {
                    Set = function(_, color, skip)
                        setColor(color, skip == true)
                    end,
                    Get = function()
                        return value
                    end
                }
            end

            return section
        end

        table.insert(library.Connections, tabButton.MouseButton1Click:Connect(function()
            for _, t in ipairs(library.Tabs) do
                t:SetActive(false)
            end
            tab:SetActive(true)
            library.ActiveTab = tab
        end))

        table.insert(library.Tabs, tab)
        if #library.Tabs == 1 then
            tab:SetActive(true)
            library.ActiveTab = tab
        end

        return tab
    end

    function self:Destroy()
        for _, conn in ipairs(self.Connections) do
            pcall(function()
                conn:Disconnect()
            end)
        end
        self.Connections = {}
        if self.Gui then
            self.Gui:Destroy()
        end
    end

    return self
end

