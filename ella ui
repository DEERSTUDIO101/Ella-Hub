                local function setState(s, skip)
                    state = s==true
                    if state then
                        tween(track, MEDIUM, {BackgroundColor3=lib.Theme.Accent})
                        tween(knob,  MEDIUM, {Position=UDim2.fromOffset(23,3), BackgroundColor3=Color3.fromRGB(255,255,255)})
