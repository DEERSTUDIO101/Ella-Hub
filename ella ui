    local tweenIn = TweenService:Create(
        holder,
        TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
        { Position = UDim2.new(0.5, 0, 0, 24) }
    )
    tweenIn:Play()

    local api = {}

    function api:SetStatus(text, color)
        sub.Text = tostring(text or "")
        if typeof(color) == "Color3" then
            sub.TextColor3 = color
        end
    end

    function api:SetTitle(text)
        title.Text = tostring(text or "")
    end

    function api:SetAutoExecute(value, skipCallback)
        setAuto(value, skipCallback == true)
    end

    function api:GetAutoExecute()
        return autoExecute
    end

    function api:GetKey()
        return keyBox.Text
    end

    function api:SetKey(value)
        keyBox.Text = tostring(value or "")
    end

    function api:Show()
        holder.Visible = true
        TweenService:Create(
            holder,
            TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
            { Position = UDim2.new(0.5, 0, 0, 24) }
        ):Play()
    end

    function api:Hide()
        local t = TweenService:Create(
            holder,
            TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
            { Position = UDim2.new(0.5, 0, 0, -180) }
        )
        t:Play()
        t.Completed:Wait()
        holder.Visible = false
    end

    function api:Destroy()
        if gui then
            gui:Destroy()
        end
    end

    api.Gui = gui
    api.Frame = holder
    api.Input = keyBox
    api.AuthenticateButton = authBtn
    api.GetKeyButton = getKeyBtn
    return api
end

getgenv().EllaLibrary = EllaLibrary
return EllaLibrary
