            function section:NewSlider(name, desc, max, min, callback)
                local data = parseArgs(name, desc, callback)
                data.Max = data.Max or tonumber(max) or 100
                data.Min = data.Min or tonumber(min) or 0
                local value = data.Default or data.Min
                local draggingSlider = false

                local f, _, descLabel = createInfoCard(controls, library.Theme, data.Title, "", 52)
                descLabel.Text = tostring(data.Description or "") .. " (" .. tostring(value) .. ")"

                local bar = Instance.new("Frame")
                bar.Size = UDim2.new(1, -16, 0, 6)
                bar.Position = UDim2.new(0, 8, 1, -10)
                bar.BackgroundColor3 = Color3.fromRGB(36, 39, 52)
                bar.BorderSizePixel = 0
                bar.Parent = f
                applyCorner(bar, 999)

                local fill = Instance.new("Frame")
                fill.Size = UDim2.new(0, 0, 1, 0)
                fill.BackgroundColor3 = library.Theme.Accent
                fill.BorderSizePixel = 0
                fill.Parent = bar
                applyCorner(fill, 999)

                local function setValue(newValue, skipCallback)
                    newValue = math.clamp(tonumber(newValue) or data.Min, data.Min, data.Max)
                    value = math.floor(newValue + 0.5)
                    local alpha = (value - data.Min) / math.max((data.Max - data.Min), 1)
                    fill.Size = UDim2.new(alpha, 0, 1, 0)
                    descLabel.Text = tostring(data.Description or "") .. " (" .. tostring(value) .. ")"
                    if not skipCallback and type(data.Callback) == "function" then
                        data.Callback(value)
                    end
                    if data.Flag then
                        library.Flags[data.Flag].Value = value
                    end
                end

                local function updateFromX(xPos)
                    local alpha = math.clamp((xPos - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    setValue(data.Min + ((data.Max - data.Min) * alpha), false)
                end

                table.insert(library.Connections, f.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = true
                        updateFromX(input.Position.X)
                    end
                end))
                table.insert(library.Connections, UserInputService.InputChanged:Connect(function(input)
                    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateFromX(input.Position.X)
                    end
                end))
                table.insert(library.Connections, UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSlider = false
                    end
                end))

                if data.Flag then
                    registerFlag(data.Flag, "Slider", data.Callback, setValue, value)
                end

                setValue(value, true)
                return {
                    Set = function(_, newValue, skip)
                        setValue(newValue, skip == true)
                    end,
                    Get = function()
                        return value
                    end
                }
            end

