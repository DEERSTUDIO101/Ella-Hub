-- ── Easing-Presets ─────────────────────────────────────────
local FAST   = TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local MEDIUM = TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local SLOW   = TweenInfo.new(0.4,  Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

-- ── Hilfsfunktionen ────────────────────────────────────────

local function resolveGuiParent()
    if typeof(gethui) == "function" then
        local ok, g = pcall(gethui)
        if ok and typeof(g) == "Instance" then return g end
    end
    if typeof(cloneref) == "function" then
        local ok, g = pcall(function() return cloneref(CoreGui) end)
        if ok and typeof(g) == "Instance" then return g end
    end
    return CoreGui
end

local function safeProtect(gui)
    if syn and syn.protect_gui then pcall(function() syn.protect_gui(gui) end) end
end

local function corner(inst, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = inst
    return c
end

local function stroke(inst, col, t, thick)
    local s = Instance.new("UIStroke")
    s.Color        = col   or Color3.fromRGB(40, 44, 62)
    s.Transparency = t     or 0
    s.Thickness    = thick or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = inst
    return s
end

local function gradient(inst, c0, c1, rot)
    local g = Instance.new("UIGradient")
    g.Color    = ColorSequence.new(c0, c1)
    g.Rotation = rot or 90
    g.Parent   = inst
    return g
end

local function padding(inst, all, l, r, t, b)
    local p = Instance.new("UIPadding")
    if all then
        p.PaddingLeft   = UDim.new(0, all)
        p.PaddingRight  = UDim.new(0, all)
        p.PaddingTop    = UDim.new(0, all)
        p.PaddingBottom = UDim.new(0, all)
    else
        p.PaddingLeft   = UDim.new(0, l or 0)
        p.PaddingRight  = UDim.new(0, r or 0)
        p.PaddingTop    = UDim.new(0, t or 0)
        p.PaddingBottom = UDim.new(0, b or 0)
    end
    p.Parent = inst
    return p
end

local function shallowCopy(t)
    local o = {} for k,v in pairs(t) do o[k]=v end return o
end

local function tween(obj, info, props)
    TweenService:Create(obj, info, props):Play()
end

local function hoverEffect(btn, normalColor, hoverColor)
    btn.MouseEnter:Connect(function()
        tween(btn, FAST, { BackgroundColor3 = hoverColor })
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, FAST, { BackgroundColor3 = normalColor })
    end)
end

local function parseArgs(name, desc, cb)
    if typeof(name) == "table" then
        local d = name
        return {
            Title       = d.Title or d.Name or d.Text or "Untitled",
            Description = d.Description or d.Desc or "",
            Callback    = d.Callback or d.CallBack or cb,
            Default     = d.Default,
            Options     = d.Options,
            Min         = d.Min,
            Max         = d.Max,
            Placeholder = d.Placeholder,
            Flag        = d.Flag,
            Multi       = d.Multi == true,
            Key         = d.Key,
            Color       = d.Color,
        }
    end
    return { Title=tostring(name or ""), Description=tostring(desc or ""), Callback=cb }
end

local function loadFloatingBar()
    local function try(fn)
        local ok, r = pcall(fn)
        return (ok and type(r)=="table" and type(r.Notify)=="function") and r or nil
    end
    return try(function()
        if type(loadfile)=="function" then
            local c=loadfile("UI Library/src.lua")
            return type(c)=="function" and c() or nil
        end
    end) or try(function()
        if type(readfile)=="function" and type(loadstring)=="function" then
            local c=loadstring(readfile("UI Library/src.lua"))
            return type(c)=="function" and c() or nil
        end
    end)
end

-- ── Haupt-Row-Builder ──────────────────────────────────────
-- Erstellt eine saubere Element-Zeile mit Titel + Desc links,
-- Widget-Slot rechts und optionalem Accent-Stripe links
local function makeRow(parent, theme, title, desc, height, accentColor)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1, 0, 0, height or 50)
    row.BackgroundColor3 = theme.Surface
    row.BorderSizePixel  = 0
    row.Parent           = parent
    corner(row, 8)
    stroke(row, theme.Border, 0, 1)

    -- Linke Accent-Linie
    if accentColor then
        local line = Instance.new("Frame")
        line.Size             = UDim2.new(0, 3, 0.6, 0)
        line.Position         = UDim2.new(0, 0, 0.2, 0)
        line.BackgroundColor3 = accentColor
        line.BorderSizePixel  = 0
        line.Parent           = row
        corner(line, 999)
    end

    local textX = accentColor and 14 or 10

    local titleLbl = Instance.new("TextLabel")
    titleLbl.BackgroundTransparency = 1
    titleLbl.Position          = UDim2.fromOffset(textX, 7)
    titleLbl.Size              = UDim2.new(1, -180, 0, 18)
    titleLbl.Font              = Enum.Font.GothamBold
    titleLbl.TextSize          = 13
    titleLbl.TextXAlignment    = Enum.TextXAlignment.Left
    titleLbl.TextColor3        = theme.Text
    titleLbl.Text              = title or ""
    titleLbl.Parent            = row

    local descLbl = Instance.new("TextLabel")
    descLbl.BackgroundTransparency = 1
    descLbl.Position        = UDim2.fromOffset(textX, 26)
    descLbl.Size            = UDim2.new(1, -180, 0, 16)
    descLbl.Font            = Enum.Font.Gotham
    descLbl.TextSize        = 11
    descLbl.TextXAlignment  = Enum.TextXAlignment.Left
    descLbl.TextColor3      = theme.SubText
    descLbl.Text            = desc or ""
    descLbl.Parent          = row

    return row, titleLbl, descLbl
end

