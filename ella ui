local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")

local FloatingBar = {}
FloatingBar.__index = FloatingBar

local MARKER_NAME = "EllaFloatingBarMarker"
local DEFAULT_ICON = "rbxassetid://7733960981"

local VARIANTS = {
    Default = {
        AccentColor = Color3.fromRGB(0, 170, 255),
        Icon = DEFAULT_ICON
    },
    Info = {
        AccentColor = Color3.fromRGB(78, 171, 255),
        Icon = "rbxassetid://7733658504"
    },
    Success = {
        AccentColor = Color3.fromRGB(64, 226, 138),
        Icon = "rbxassetid://6031094678"
    },
    Warn = {
        AccentColor = Color3.fromRGB(255, 196, 71),
        Icon = "rbxassetid://6031091004"
    },
    Error = {
        AccentColor = Color3.fromRGB(255, 95, 95),
        Icon = "rbxassetid://6031071053"
    }
}

local function resolveGuiParent()
    if typeof(gethui) == "function" then
        local ok, result = pcall(gethui)
        if ok and typeof(result) == "Instance" then
            return result
        end
    end

    if typeof(cloneref) == "function" then
        local ok, result = pcall(function()
            return cloneref(CoreGui)
        end)
        if ok and typeof(result) == "Instance" then
            return result
        end
    end

    return CoreGui
end

local function normalizeImageSource(imageValue)
    if imageValue == nil then
        return ""
    end

    local asString = tostring(imageValue)
    if asString == "" then
        return ""
    end

    if string.find(asString, "rbxassetid://", 1, true)
        or string.find(asString, "http://", 1, true)
        or string.find(asString, "https://", 1, true) then
        return asString
    end

    if string.match(asString, "^%d+$") then
        return "rbxassetid://" .. asString
    end

    return asString
end

local function safeProtectGui(gui)
    if syn and syn.protect_gui then
        pcall(function()
            syn.protect_gui(gui)
        end)
    end
end

local function deepCleanup(parent)
    for _, child in ipairs(parent:GetChildren()) do
        if child:IsA("ScreenGui") and child:FindFirstChild(MARKER_NAME) then
            pcall(function()
                child:Destroy()
            end)
        end
    end
end

local function safeCall(fn, ...)
    if type(fn) ~= "function" then
        return
    end
    local ok, err = pcall(fn, ...)
    if not ok then
        warn("[EllaFloatingBar] callback error:", err)
    end
end

function FloatingBar.new(options)
    options = options or {}

    local self = setmetatable({}, FloatingBar)
    self.ParentOverride = options.Parent
    self.Width = options.Width or 340
    self.Height = options.Height or 64
    self.MarginTop = options.MarginTop or 24
    self.MobileMarginTop = options.MobileMarginTop or 16
    self.DefaultDuration = options.DefaultDuration or 2.8
    self.AccentColor = options.AccentColor or Color3.fromRGB(0, 170, 255)
    self.UIAnimationsEnabled = options.UIAnimationsEnabled ~= false
    self.MaxQueue = options.MaxQueue or 20
    self.QueuePaused = false
    self.Debug = options.Debug == true
    self.OnShow = options.OnShow
    self.OnHide = options.OnHide
    self.OnQueueEmpty = options.OnQueueEmpty
    self.Theme = {
        Background = options.BackgroundColor or Color3.fromRGB(18, 18, 22),
        BodyText = options.BodyTextColor or Color3.fromRGB(200, 205, 220),
        TitleText = options.TitleTextColor or Color3.fromRGB(245, 245, 250),
        StrokeTransparency = options.StrokeTransparency or 0.45,
        BackgroundTransparency = options.BackgroundTransparency or 0.08,
        ProgressTrackTransparency = options.ProgressTrackTransparency or 0.86
    }

    self.Queue = {}
    self.IsShowing = false
    self.IsPumping = false
    self.NextId = 0
    self.ActiveItem = nil
    self.ActiveProgressTween = nil
    self.DismissRequested = false
    self.DismissInstant = false

    self:_createGui()
    return self
end

