    local tabList = Instance.new("ScrollingFrame")
    tabList.Name = "TabList"
    tabList.Position = UDim2.fromOffset(12, 56)
    tabList.Size = UDim2.new(0, 210, 1, -68)
    tabList.BackgroundColor3 = self.Theme.TopBar
    tabList.BorderSizePixel = 0
    tabList.ScrollBarImageColor3 = Color3.fromRGB(80, 85, 108)
    tabList.ScrollBarThickness = 3
    tabList.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabList.Parent = root
    applyCorner(tabList, 10)
    self.TabList = tabList

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.Padding = UDim.new(0, 6)
    tabLayout.Parent = tabList

    local pages = Instance.new("Frame")
    pages.Position = UDim2.fromOffset(232, 56)
    pages.Size = UDim2.new(1, -244, 1, -68)
    pages.BackgroundColor3 = self.Theme.TopBar
    pages.BorderSizePixel = 0
    pages.Parent = root
    applyCorner(pages, 10)
    self.Pages = pages

    local function trackThemeObject(instance, token)
        self.ThemeObjects[instance] = token
    end

    trackThemeObject(root, "Background")
    trackThemeObject(top, "TopBar")
    trackThemeObject(title, "Text")
    trackThemeObject(tabList, "TopBar")
    trackThemeObject(pages, "TopBar")

    local function recalcTabCanvas()
        tabList.CanvasSize = UDim2.new(0, 0, 0, tabLayout.AbsoluteContentSize.Y + 10)
    end
    table.insert(self.Connections, tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(recalcTabCanvas))
    recalcTabCanvas()

    local dragging = false
    local dragStart
    local startPos

    table.insert(self.Connections, top.InputBegan:Connect(function(input)
        if not self.Draggable then
            return
        end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = root.Position
        end
    end))

    table.insert(self.Connections, top.InputEnded:Connect(function(input)
        if not self.Draggable then
            return
        end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end))

    table.insert(self.Connections, UserInputService.InputChanged:Connect(function(input)
        if not self.Draggable then
            return
        end
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            root.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end))

    table.insert(self.Connections, UserInputService.InputBegan:Connect(function(input, processed)
        if processed then
            return
        end
        if input.KeyCode == self.ToggleKey then
            self:Toggle()
            return
        end

        for _, entry in pairs(self.Flags) do
            if entry and entry.Type == "Keybind" and entry.Key == input.KeyCode and type(entry.Callback) == "function" then
                pcall(entry.Callback, input.KeyCode)
            end
        end
    end))

    table.insert(self.Connections, closeButton.MouseButton1Click:Connect(function()
        self:Destroy()
    end))

    table.insert(self.Connections, minimizeButton.MouseButton1Click:Connect(function()
        self:Toggle()
    end))

    function self:Toggle()
        self.MainVisible = not self.MainVisible
        root.Visible = self.MainVisible
    end

    function self:SetToggleKey(keyCode)
        if typeof(keyCode) == "EnumItem" and keyCode.EnumType == Enum.KeyCode then
            self.ToggleKey = keyCode
        end
    end

    function self:SetTopDock(enabled)
        if enabled then
            self.LayoutMode = "TopDock"
            self.Draggable = false
            root.AnchorPoint = Vector2.new(0.5, 0)
            root.Size = self.TopDockSize
            TweenService:Create(root, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
                Position = UDim2.new(0.5, 0, 0, self.TopOffset)
            }):Play()
        else
            self.LayoutMode = "Window"
            self.Draggable = true
            root.AnchorPoint = Vector2.new(0, 0)
            root.Size = self.WindowedSize
            TweenService:Create(root, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
                Position = UDim2.new(0.5, -380, 0.5, -245)
            }):Play()
        end
    end

    function self:Notify(dataOrTitle, content, duration)
        if not self.Notifier then
            return
        end
        if type(dataOrTitle) == "table" then
            self.Notifier:Notify(dataOrTitle)
        else
            self.Notifier:Notify({
                Title = tostring(dataOrTitle or "Notification"),
                Content = tostring(content or ""),
                Duration = duration
            })
        end
    end

    function self:SetFlag(flag, value, skipCallback)
        if not flag then
            return
        end
        local slot = self.Flags[flag]
        if slot then
            slot.Value = value
            if self.FlagSetters[flag] then
                self.FlagSetters[flag](value, skipCallback == true)
            end
        else
            self.Flags[flag] = { Value = value, Type = "Raw" }
        end
    end

    function self:GetFlag(flag)
        local slot = self.Flags[flag]
        return slot and slot.Value or nil
    end

    function self:UpdateTheme(theme)
        if typeof(theme) ~= "table" then
            return
        end

        for key, value in pairs(theme) do
            if self.Theme[key] ~= nil and typeof(value) == "Color3" then
                self.Theme[key] = value
            end
        end

        for instance, token in pairs(self.ThemeObjects) do
            if instance and instance.Parent and self.Theme[token] then
                if instance:IsA("TextLabel") or instance:IsA("TextButton") or instance:IsA("TextBox") then
                    if token == "Text" or token == "SubText" then
                        instance.TextColor3 = self.Theme[token]
                    else
                        instance.BackgroundColor3 = self.Theme[token]
                    end
                elseif instance:IsA("UIStroke") then
                    instance.Color = self.Theme[token]
                elseif instance:IsA("Frame") or instance:IsA("ScrollingFrame") then
                    instance.BackgroundColor3 = self.Theme[token]
                end
            end
        end
    end

    function self:SaveConfig()
        if not self.Config.Enabled then
            return false, "ConfigurationSaving disabled"
        end
        if type(writefile) ~= "function" then
            return false, "writefile unavailable"
        end

        if type(makefolder) == "function" and type(isfolder) == "function" and not isfolder(self.Config.Folder) then
            pcall(function()
                makefolder(self.Config.Folder)
            end)
        end

        local data = {}
        for name, entry in pairs(self.Flags) do
            if entry and entry.Value ~= nil and entry.Type ~= "Keybind" then
                local value = entry.Value
                if typeof(value) == "Color3" then
                    data[name] = {
                        __type = "Color3",
                        R = math.floor(value.R * 255 + 0.5),
                        G = math.floor(value.G * 255 + 0.5),
                        B = math.floor(value.B * 255 + 0.5)
                    }
                else
                    data[name] = value
                end
            end
        end

        local path = string.format("%s/%s", self.Config.Folder, self.Config.File)
        local ok, err = pcall(function()
            writefile(path, HttpService:JSONEncode(data))
        end)
        if not ok then
            return false, err
        end
        return true
    end

    function self:LoadConfig()
        if not self.Config.Enabled then
            return false, "ConfigurationSaving disabled"
        end
        if type(readfile) ~= "function" or type(isfile) ~= "function" then
            return false, "readfile/isfile unavailable"
        end

        local path = string.format("%s/%s", self.Config.Folder, self.Config.File)
        if not isfile(path) then
            return false, "Config file missing"
        end

        local okRead, raw = pcall(function()
            return readfile(path)
        end)
        if not okRead then
            return false, raw
        end

        local okDecode, data = pcall(function()
            return HttpService:JSONDecode(raw)
        end)
        if not okDecode or type(data) ~= "table" then
            return false, "Invalid JSON"
        end

        for flag, value in pairs(data) do
            if type(value) == "table" and value.__type == "Color3" then
                value = Color3.fromRGB(value.R or 0, value.G or 0, value.B or 0)
            end
            self:SetFlag(flag, value)
        end

        return true
    end

    local function createTabButton(text)
        local tabButton = Instance.new("TextButton")
